<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>追加工程 - 水平ノズル検査</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
  <style>
    body { background: #f5f5f5; font-family: sans-serif; }
    .container { max-width: 1200px; margin-top: 2rem; }
    .header { background: white; padding: 2rem; border-radius: 8px; margin-bottom: 2rem; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    .workflow { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .workflow-step { background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-left: 4px solid #0d6efd; text-align: center; }
    .step-number { display: inline-block; width: 32px; height: 32px; line-height: 32px; background: #0d6efd; color: white; border-radius: 50%; font-weight: bold; margin-bottom: 0.5rem; }
    .step-title { font-weight: 600; color: #212529; margin: 0.5rem 0; font-size: 0.95rem; }
    .step-desc { font-size: 0.85rem; color: #6c757d; }
    .form-section { background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); margin-bottom: 1.5rem; }
    .form-section h3 { font-size: 1.1rem; font-weight: 600; margin-bottom: 1rem; color: #212529; }
    .upload-zone { border: 2px dashed #b0c4de; border-radius: 8px; background: white; cursor: pointer; padding: 2rem; transition: border-color 0.2s, background 0.2s; text-align: center; }
    .upload-zone:hover, .upload-zone.drag-over { border-color: #0d6efd; background: #f0f6ff; }
    .upload-icon { font-size: 2rem; margin-bottom: 0.5rem; }
    .form-control { border-radius: 6px; border: 1px solid #dee2e6; }
    .form-control:focus { border-color: #0d6efd; box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.25); }
    .form-label { font-weight: 600; font-size: 0.9rem; color: #212529; margin-bottom: 0.5rem; }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .stat-card { background: #f8f9fa; padding: 1rem; border-radius: 6px; text-align: center; }
    .stat-label { font-size: 0.8rem; color: #6c757d; text-transform: uppercase; font-weight: 600; margin-bottom: 0.5rem; }
    .stat-value { font-size: 1.75rem; font-weight: 700; color: #0d6efd; }
    .alert-box { padding: 1rem; border-radius: 6px; margin-bottom: 1rem; display: flex; align-items: flex-start; gap: 0.75rem; }
    .alert-info { background: #d1ecf1; border-left: 4px solid #0c5460; color: #0c5460; }
    .alert-success { background: #d4edda; border-left: 4px solid #155724; color: #155724; }
    .alert-warning { background: #fff3cd; border-left: 4px solid #856404; color: #856404; }
    .alert-error { background: #f8d7da; border-left: 4px solid #721c24; color: #721c24; }
    .alert-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 2px; }
    .alert-content { font-size: 0.9rem; }
    .btn { border-radius: 6px; font-weight: 600; transition: all 0.2s; }
    .btn-primary { background: #0d6efd; border: none; }
    .btn-primary:hover { background: #0b5ed7; transform: translateY(-2px); box-shadow: 0 4px 8px rgba(13,110,253,0.3); }
    .btn-primary:active { transform: translateY(0); }
    .btn-outline-secondary { color: #6c757d; border-color: #dee2e6; }
    .btn-outline-secondary:hover { background: #f8f9fa; }
    .loading-spinner { display: inline-block; width: 16px; height: 16px; border: 2px solid #f0f0f0; border-top: 2px solid #0d6efd; border-radius: 50%; animation: spin 0.6s linear infinite; margin-right: 0.5rem; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .form-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem; }
    .form-row .form-group { margin-bottom: 0; }
    .help-text { font-size: 0.85rem; color: #6c757d; margin-top: 0.3rem; }
    .breadcrumb-custom { font-size: 0.9rem; color: #6c757d; margin-bottom: 1rem; }
    .breadcrumb-custom a { color: #0d6efd; text-decoration: none; }
    .breadcrumb-custom a:hover { text-decoration: underline; }

    /* ===== SAVED FILES LIST ===== */
    .saved-files-panel { background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); margin-bottom: 1.5rem; overflow: hidden; }
    .saved-files-header { background: #f8f9fa; padding: 1rem 1.5rem; border-bottom: 1px solid #dee2e6; display: flex; justify-content: space-between; align-items: center; cursor: pointer; user-select: none; }
    .saved-files-header:hover { background: #e9ecef; }
    .saved-files-header h3 { font-size: 1.1rem; font-weight: 600; margin: 0; color: #212529; }
    .saved-files-body { padding: 1.5rem; }
    .toggle-icon { transition: transform 0.2s; }
    .toggle-icon.open { transform: rotate(180deg); }
    .empty-state { text-align: center; padding: 2rem; color: #6c757d; font-size: 0.9rem; }

    /* File row */
    .file-row { border: 1px solid #dee2e6; border-radius: 8px; margin-bottom: 0.75rem; overflow: hidden; transition: box-shadow 0.15s; }
    .file-row:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .file-row-main { display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 1rem; background: white; }
    .file-row-info { flex: 1; }
    .file-row-name { font-weight: 600; font-size: 0.9rem; color: #212529; }
    .file-row-meta { font-size: 0.8rem; color: #6c757d; margin-top: 0.2rem; }
    .file-row-actions { display: flex; gap: 0.5rem; align-items: center; flex-shrink: 0; }

    /* Pingauge inline section — shown below each file row */
    .pingauge-section { background: #f8f9fa; border-top: 1px solid #dee2e6; padding: 0.75rem 1rem; display: none; }
    .pingauge-section.visible { display: block; }
    .pingauge-inner { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
    .pingauge-label { font-size: 0.85rem; font-weight: 600; color: #212529; white-space: nowrap; }
    .pingauge-input { width: 140px; font-size: 0.9rem; padding: 0.35rem 0.6rem; border: 2px solid #0d6efd; border-radius: 6px; }
    .pingauge-hint { font-size: 0.78rem; color: #6c757d; }
    .pingauge-saved-badge { font-size: 0.78rem; background: #d4edda; color: #155724; padding: 2px 8px; border-radius: 10px; display: none; }
  </style>
</head>
<body>
<div class="container">

<div class="breadcrumb-custom"><a href="/">← ホーム</a> / 追加工程</div>

<div id="tuikaHelpPanel" style="
  background: white;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  margin-bottom: 1.25rem;
  overflow: hidden;
  border: 1px solid #e9ecef;
">
  <!-- Collapsible header -->
  <div
    onclick="toggleTuikaHelp()"
    id="tuikaHelpToggle"
    style="
      display: flex; justify-content: space-between; align-items: center;
      padding: 0.7rem 1.25rem; cursor: pointer; user-select: none;
      background: #f8f9fa;
      transition: background 0.15s;
    "
    onmouseenter="this.style.background='#eef2f7'"
    onmouseleave="this.style.background='#f8f9fa'"
  >
    <div style="display:flex; align-items:center; gap:0.6rem;">
      <span style="font-size:0.95rem;">📖</span>
      <span style="font-weight:600; font-size:0.88rem; color:#2c3e50;">
        使い方ガイド — 追加工程（LOT検査シート生成）
      </span>
      <span style="font-size:0.75rem; color:#6c757d; font-style:italic;">クリックで開閉</span>
    </div>
    <span id="tuikaHelpChevron" style="font-size:0.85rem; color:#6c757d; transition:transform 0.2s;">▼</span>
  </div>

  <!-- Collapsible body -->
  <div id="tuikaHelpBody" style="display:none; padding:1.4rem 1.5rem; border-top:1px solid #e9ecef;">

    <!-- ── What is this page ── -->
    <div style="margin-bottom:1.5rem;">
      <h4 style="font-size:0.95rem; font-weight:700; color:#2c3e50; margin-bottom:0.6rem;">
        ➕ このページの目的
      </h4>
      <p style="font-size:0.85rem; color:#444; line-height:1.7; margin:0;">
        3D測定機の <code>.txt</code> ファイルから寸法値（DISTANCE・INT-CIRCLE）を自動抽出し、
        客先提出用の <strong>LOT検査シート（Excel）</strong> を生成・クラウド保存するページです。<br>
        ピンゲージ測定値・重量・判定（OK）は<strong>保存後</strong>に入力し、最終的なExcelをダウンロードします。
      </p>
    </div>

    <!-- ── Step-by-step flow ── -->
    <div style="margin-bottom:1.5rem;">
      <h4 style="font-size:0.95rem; font-weight:700; color:#2c3e50; margin-bottom:0.75rem;">
        🔢 操作手順
      </h4>

      <div style="display:flex; flex-direction:column; gap:0.6rem;">

        <div style="display:flex; gap:0.75rem; align-items:flex-start;">
          <div style="min-width:26px; height:26px; background:#0d6efd; color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.82rem; flex-shrink:0;">1</div>
          <div style="font-size:0.85rem; color:#333; line-height:1.65;">
            <strong>TXTファイルをドロップ</strong>（または「選択」ボタン）<br>
            <span style="color:#6c757d;">3D測定機出力の <code>.txt</code> を1本ずつ読み込みます。DISTANCE値（4点）と INT-CIRCLE値が自動抽出されます。</span>
          </div>
        </div>

        <div style="display:flex; gap:0.75rem; align-items:flex-start;">
          <div style="min-width:26px; height:26px; background:#0d6efd; color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.82rem; flex-shrink:0;">2</div>
          <div style="font-size:0.85rem; color:#333; line-height:1.65;">
            <strong>LOT番号・検査日を入力</strong><br>
            <span style="color:#6c757d;">
              LOT番号は <code>LOT234(234-245)</code> のような形式で入力。<br>
              検査日は <code>YYYY/MM/DD</code> 形式（例: <code>2025/03/23</code>）。
            </span>
          </div>
        </div>

        <div style="display:flex; gap:0.75rem; align-items:flex-start;">
          <div style="min-width:26px; height:26px; background:#0d6efd; color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.82rem; flex-shrink:0;">3</div>
          <div style="font-size:0.85rem; color:#333; line-height:1.65;">
            <strong>「📊 Excel を生成 &amp; 保存」ボタン</strong><br>
            <span style="color:#6c757d;">
              テンプレート <code>LOT_template.xlsx</code> に測定値を書き込み、クラウド（Appwrite）へ自動保存します。<br>
              ピンゲージ・重量・判定はこの時点では空欄のまま保存されます。
            </span>
          </div>
        </div>

        <div style="display:flex; gap:0.75rem; align-items:flex-start;">
          <div style="min-width:26px; height:26px; background:#fd7e14; color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.82rem; flex-shrink:0;">4</div>
          <div style="font-size:0.85rem; color:#333; line-height:1.65;">
            <strong>一覧の「✏️ ピンゲージ」ボタンから値を入力 → 「💾 保存」</strong><br>
            <span style="color:#6c757d;">
              保存済みLOT一覧が自動で開きます。対象行の「✏️ ピンゲージ」を押すと入力欄が展開されます。<br>
              値を入力してEnterまたは「💾 保存」を押してください。<br>
              ⚠ ピンゲージ値が未保存の場合、ダウンロードはブロックされます。
            </span>
          </div>
        </div>

        <div style="display:flex; gap:0.75rem; align-items:flex-start;">
          <div style="min-width:26px; height:26px; background:#198754; color:white; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.82rem; flex-shrink:0;">5</div>
          <div style="font-size:0.85rem; color:#333; line-height:1.65;">
            <strong>「⬇️ DL」ボタンでExcelをダウンロード</strong><br>
            <span style="color:#6c757d;">
              ダウンロード時にExcelへ自動記入される項目：<br>
              <span style="display:inline-block; margin-top:3px;">
                <span style="background:#e9ecef; border-radius:3px; padding:1px 6px; font-size:0.8rem; font-family:monospace;">B4</span> ピンゲージ値 &nbsp;
                <span style="background:#e9ecef; border-radius:3px; padding:1px 6px; font-size:0.8rem; font-family:monospace;">B5</span> 重量（ホームで入力済みの値を自動取得） &nbsp;
                <span style="background:#e9ecef; border-radius:3px; padding:1px 6px; font-size:0.8rem; font-family:monospace;">B6</span> OK（固定）
              </span>
            </span>
          </div>
        </div>

      </div>
    </div>

    <!-- ── Cell mapping reference ── -->
    <div style="margin-bottom:1.5rem;">
      <h4 style="font-size:0.95rem; font-weight:700; color:#2c3e50; margin-bottom:0.6rem;">
        📋 Excelセルへの書き込み対応表
      </h4>
      <table style="width:100%; border-collapse:collapse; font-size:0.82rem;">
        <thead>
          <tr style="background:#f8f9fa;">
            <th style="padding:6px 10px; border:1px solid #dee2e6; text-align:left; width:60px;">セル</th>
            <th style="padding:6px 10px; border:1px solid #dee2e6; text-align:left;">内容</th>
            <th style="padding:6px 10px; border:1px solid #dee2e6; text-align:left; width:160px;">タイミング</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td style="padding:6px 10px; border:1px solid #dee2e6; font-family:monospace; font-weight:700;">B1</td>
            <td style="padding:6px 10px; border:1px solid #dee2e6;">LOT番号</td>
            <td style="padding:6px 10px; border:1px solid #dee2e6;">生成時</td>
          </tr>
          <tr style="background:#fafafa;">
            <td style="padding:6px 10px; border:1px solid #dee2e6; font-family:monospace; font-weight:700;">B2</td>
            <td style="padding:6px 10px; border:1px solid #dee2e6;">検査日</td>
            <td style="padding:6px 10px; border:1px solid #dee2e6;">生成時</td>
          </tr>
          <tr>
            <td style="padding:6px 10px; border:1px solid #dee2e6; font-family:monospace; font-weight:700;">B3</td>
            <td style="padding:6px 10px; border:1px solid #dee2e6;">LOTプレフィックス（例: LOT234）</td>
            <td style="padding:6px 10px; border:1px solid #dee2e6;">生成時</td>
          </tr>
          <tr style="background:#fff8e1;">
            <td style="padding:6px 10px; border:1px solid #dee2e6; font-family:monospace; font-weight:700;">B4</td>
            <td style="padding:6px 10px; border:1px solid #dee2e6;"><strong>ピンゲージ値</strong>（✏️ ピンゲージ欄で入力）</td>
            <td style="padding:6px 10px; border:1px solid #dee2e6;">⬇️ DL時</td>
          </tr>
          <tr style="background:#fff8e1;">
            <td style="padding:6px 10px; border:1px solid #dee2e6; font-family:monospace; font-weight:700;">B5</td>
            <td style="padding:6px 10px; border:1px solid #dee2e6;"><strong>重量</strong>（ホームの重量入力から自動取得）</td>
            <td style="padding:6px 10px; border:1px solid #dee2e6;">⬇️ DL時</td>
          </tr>
          <tr style="background:#fff8e1;">
            <td style="padding:6px 10px; border:1px solid #dee2e6; font-family:monospace; font-weight:700;">B6</td>
            <td style="padding:6px 10px; border:1px solid #dee2e6;"><strong>判定: OK</strong>（固定）</td>
            <td style="padding:6px 10px; border:1px solid #dee2e6;">⬇️ DL時</td>
          </tr>
          <tr>
            <td style="padding:6px 10px; border:1px solid #dee2e6; font-family:monospace; font-weight:700;">A列</td>
            <td style="padding:6px 10px; border:1px solid #dee2e6;">DISTANCE値 × 4点 → INT-CIRCLE値（順番通り）</td>
            <td style="padding:6px 10px; border:1px solid #dee2e6;">生成時</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- ── Notes ── -->
    <div style="font-size:0.83rem; color:#555; line-height:1.75; background:#f8f9fa; border-radius:6px; padding:0.85rem 1rem;">
      <div style="margin-bottom:0.3rem;"><strong>📌 注意事項</strong></div>
      <div>・TXTは1回の操作で1本のみ対応です（複数ロットは順番に繰り返してください）</div>
      <div>・重量はホームの「ファイル一覧」から入力・保存しておく必要があります。未入力の場合 B5 は空欄になります</div>
      <div>・ピンゲージが未保存の状態では ⬇️ DL がブロックされます（警告が表示されます）</div>
      <div>・保存済みファイルはクラウドに残るため、後日 DL し直すことができます。不要なら 🗑 で削除してください</div>
      <div>・テンプレートファイル <code>LOT_template.xlsx</code> はリポジトリ内に固定されており、アップロード不要です</div>
    </div>

  </div><!-- /tuikaHelpBody -->
</div><!-- /tuikaHelpPanel -->

<script>
  function toggleTuikaHelp() {
    const body    = document.getElementById('tuikaHelpBody');
    const chevron = document.getElementById('tuikaHelpChevron');
    const isOpen  = body.style.display !== 'none';
    body.style.display      = isOpen ? 'none' : 'block';
    chevron.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
  }
</script>

  <div class="header">
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;">
      <div>
        <h1>追加工程</h1>
        <p style="color:#6c757d;margin:0;">測定データを自動的にExcelに転記します</p>
      </div>
      <div style="text-align:right;font-size:0.9rem;">
        <div style="color:#6c757d;">ログイン中: <strong><%= displayName %></strong></div>
        <form action="/logout" method="POST" style="display:inline;margin-top:0.5rem;">
          <button type="submit" class="btn btn-sm btn-outline-secondary">Logout</button>
        </form>
      </div>
    </div>
  </div>

  <div class="workflow">
    <div class="workflow-step">
      <div class="step-number">1</div>
      <div class="step-title">データ選択</div>
      <div class="step-desc">.txtファイルから測定値を抽出</div>
    </div>
    <div class="workflow-step">
      <div class="step-number">2</div>
      <div class="step-title">LOT情報入力</div>
      <div class="step-desc">番号と検査日を指定</div>
    </div>
    <div class="workflow-step">
      <div class="step-number">3</div>
      <div class="step-title">保存 → ピンゲージ入力 → DL</div>
      <div class="step-desc">クラウド保存後、追加値を入力してDL</div>
    </div>
  </div>

  <div id="alertContainer"></div>

  <!-- ===== SAVED FILES LIST ===== -->
  <div class="saved-files-panel">
    <div class="saved-files-header" onclick="toggleSavedFiles()">
      <h3>📁 保存済みLOT検査シート <span id="fileCount" style="font-size:0.85rem;color:#6c757d;font-weight:400;"></span></h3>
      <span class="toggle-icon" id="toggleIcon">▼</span>
    </div>
    <div class="saved-files-body" id="savedFilesBody" style="display:none;">
      <div style="font-size:0.82rem;color:#6c757d;margin-bottom:1rem;">
        💡 ピンゲージ値を入力して <strong>保存</strong> してから <strong>⬇️ DL</strong> してください。保存済みの場合はそのままDL可能です。
      </div>
      <div id="savedFilesList"><div class="empty-state">読み込み中...</div></div>
    </div>
  </div>

  <!-- Template status -->
  <div class="form-section">
    <div class="alert-info alert-box">
      <div class="alert-icon">✓</div>
      <div class="alert-content">
        <strong>テンプレート: LOT_template.xlsx</strong>
        <div style="font-size:0.85rem;margin-top:0.3rem;">リポジトリに含まれています。アップロード不要です。</div>
      </div>
    </div>
  </div>

  <!-- Data file upload -->
  <div class="form-section">
    <h3>測定データファイル</h3>
    <input type="file" id="dataFile" accept=".txt,.dat,.csv" style="display:none;">
    <div id="dropZone" class="upload-zone">
      <div class="upload-icon">📄</div>
      <div style="font-size:0.9rem;color:#6c757d;">
        <div style="margin-bottom:0.5rem;">ファイルをドラッグ&ドロップまたは</div>
        <button class="btn btn-sm btn-outline-primary" onclick="event.stopPropagation();document.getElementById('dataFile').click();">📁 選択</button>
        <div style="margin-top:0.5rem;font-size:0.8rem;color:#aaa;">対応形式: .txt, .dat, .csv</div>
      </div>
    </div>
    <div id="dataName" style="display:none;margin-top:1rem;">
      <div class="alert-success alert-box">
        <div class="alert-icon">✓</div>
        <div class="alert-content" id="dataNameText"></div>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div id="statsContainer" style="display:none;">
    <div class="form-section">
      <h3>抽出結果</h3>
      <div class="stats-grid">
        <div class="stat-card"><div class="stat-label">取得レコード</div><div class="stat-value" id="recordCount">0</div></div>
        <div class="stat-card"><div class="stat-label">DISTANCE値</div><div class="stat-value" id="distanceCount">0</div></div>
        <div class="stat-card"><div class="stat-label">INT-CIRCLE値</div><div class="stat-value" id="intCircleCount">0</div></div>
      </div>
    </div>
  </div>

  <!-- LOT info form -->
  <div class="form-section">
    <h3>LOT情報入力</h3>
    <div class="form-row">
      <div class="form-group">
        <label for="lotNumber" class="form-label">LOT番号 *</label>
        <input type="text" id="lotNumber" class="form-control" placeholder="例: LOT234(234-245)">
        <div class="help-text">LOT番号を入力してください</div>
      </div>
      <div class="form-group">
        <label for="inspectionDate" class="form-label">検査日 (YYYY/MM/DD) *</label>
        <input type="text" id="inspectionDate" class="form-control" placeholder="例: 2025/03/23">
        <div class="help-text">検査日をYYYY/MM/DD形式で入力</div>
      </div>
    </div>
    <div class="alert-info alert-box">
      <div class="alert-icon">💡</div>
      <div class="alert-content">ピンゲージ値・重量は保存後の一覧画面から入力してください。</div>
    </div>
  </div>

  <!-- Action buttons -->
  <div class="form-section">
    <div style="display:flex;gap:1rem;flex-wrap:wrap;">
      <button id="processBtn" class="btn btn-primary" onclick="processData()">📊 Excel を生成 &amp; 保存</button>
      <button class="btn btn-outline-secondary" onclick="resetForm()">🔄 リセット</button>
    </div>
  </div>

  <div id="downloadContainer" style="display:none;">
    <div class="form-section">
      <div class="alert-success alert-box">
        <div class="alert-icon">✓</div>
        <div class="alert-content">
          <strong>クラウドへの保存完了</strong>
          <div style="font-size:0.85rem;margin-top:0.3rem;">上の一覧からピンゲージ値を入力してDLしてください。</div>
          <div id="fileInfo" style="font-size:0.8rem;margin-top:0.5rem;color:#333;"></div>
        </div>
      </div>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/exceljs@4.3.0/dist/exceljs.min.js"></script>
<script>
  let parsedData = null;
  let distanceValues = [];
  let intCircleValues = [];
  let processedWorkbook = null;
  let exportFilename = null;
  let savedFilesOpen = false;
  let savedFilesLoaded = false;

  // ===== SAVED FILES PANEL =====

  function toggleSavedFiles() {
    savedFilesOpen = !savedFilesOpen;
    document.getElementById('savedFilesBody').style.display = savedFilesOpen ? 'block' : 'none';
    document.getElementById('toggleIcon').classList.toggle('open', savedFilesOpen);
    if (savedFilesOpen && !savedFilesLoaded) loadSavedFiles();
  }

  async function loadSavedFiles() {
    const listEl = document.getElementById('savedFilesList');
    listEl.innerHTML = '<div class="empty-state">読み込み中...</div>';
    try {
      const res = await fetch('/api/tuika/list');
      const data = await res.json();

      if (!data.success || data.files.length === 0) {
        listEl.innerHTML = '<div class="empty-state">保存されたファイルはありません</div>';
        document.getElementById('fileCount').textContent = '';
        savedFilesLoaded = true;
        return;
      }

      document.getElementById('fileCount').textContent = `(${data.files.length}件)`;

      listEl.innerHTML = data.files.map(f => {
        const hasPingauge = f.pingauge && f.pingauge.trim() !== '';
        return `
        <div class="file-row" id="row-${f.$id}">
          <div class="file-row-main">
            <div class="file-row-info">
              <div class="file-row-name">📄 ${f.filename}</div>
              <div class="file-row-meta">
                LOT: ${f.lot_number} &nbsp;|&nbsp; 検査日: ${f.inspection_date}
                &nbsp;|&nbsp; 保存者: ${f.created_by}
                &nbsp;|&nbsp; ${formatDate(f.created_at)}
                ${hasPingauge ? `&nbsp;|&nbsp; ピンゲージ: <strong style="color:#155724;">${f.pingauge}</strong>` : '<span style="color:#856404;font-size:0.78rem;">&nbsp;|&nbsp; ⚠ ピンゲージ未入力</span>'}
              </div>
            </div>
            <div class="file-row-actions">
              <button class="btn btn-sm btn-outline-secondary"
                onclick="togglePingaugeSection('${f.$id}', '${f.lot_number}')"
                id="pg-toggle-${f.$id}"
                title="ピンゲージ値を入力">
                ✏️ ピンゲージ
              </button>
              <button class="btn btn-sm btn-primary"
                onclick="downloadWithExtras('${f.$id}', '${f.filename}', '${f.lot_number}', '${f.inspection_date}')"
                id="dl-btn-${f.$id}">
                ⬇️ ダウンロード
              </button>
              <button class="btn btn-sm btn-outline-danger" onclick="deleteFile('${f.$id}')">🗑</button>
            </div>
          </div>
          <!-- Inline pingauge input section -->
          <div class="pingauge-section" id="pg-section-${f.$id}">
            <div class="pingauge-inner">
              <span class="pingauge-label">ピンゲージ値 (B4):</span>
              <input type="text" class="pingauge-input form-control"
                id="pg-input-${f.$id}"
                value="${hasPingauge ? f.pingauge : ''}"
                placeholder="例: 8.00"
                onkeydown="if(event.key==='Enter') savePingauge('${f.$id}', '${f.lot_number}', '${f.inspection_date}')">
              <button class="btn btn-sm btn-success"
                onclick="savePingauge('${f.$id}', '${f.lot_number}', '${f.inspection_date}')"
                id="pg-save-${f.$id}">
                💾 保存
              </button>
              <span class="pingauge-saved-badge" id="pg-badge-${f.$id}">✓ 保存済み</span>
              <span class="pingauge-hint">保存後に ⬇️ DL でExcelを取得できます (B4=ピンゲージ, B5=重量, B6=OK)</span>
            </div>
          </div>
        </div>`;
      }).join('');

      savedFilesLoaded = true;
    } catch (err) {
      listEl.innerHTML = `<div class="empty-state" style="color:#721c24;">読み込みエラー: ${err.message}</div>`;
    }
  }

  function togglePingaugeSection(metaId) {
    const section = document.getElementById(`pg-section-${metaId}`);
    const isVisible = section.classList.contains('visible');
    section.classList.toggle('visible', !isVisible);
    if (!isVisible) {
      setTimeout(() => document.getElementById(`pg-input-${metaId}`)?.focus(), 50);
    }
  }

  async function savePingauge(metaId, lotNumber, inspectionDate) {
    const input = document.getElementById(`pg-input-${metaId}`);
    const pingauge = input.value.trim();
    if (!pingauge) { showAlert('ピンゲージ値を入力してください', 'error'); return; }

    const saveBtn = document.getElementById(`pg-save-${metaId}`);
    saveBtn.disabled = true;
    saveBtn.innerHTML = '<span class="loading-spinner"></span>';

    try {
      const res = await fetch(`/api/tuika/${metaId}/pingauge`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ pingauge })
      });
      const data = await res.json();
      if (data.success) {
        const badge = document.getElementById(`pg-badge-${metaId}`);
        badge.style.display = 'inline-block';
        saveBtn.innerHTML = '💾 保存';
        saveBtn.disabled = false;
        showAlert(`ピンゲージ値 "${pingauge}" を保存しました`, 'success');
        // Refresh the list so meta row shows updated value
        savedFilesLoaded = false;
        loadSavedFiles();
      } else {
        showAlert(`保存エラー: ${data.error}`, 'error');
        saveBtn.innerHTML = '💾 保存';
        saveBtn.disabled = false;
      }
    } catch (err) {
      showAlert(`保存エラー: ${err.message}`, 'error');
      saveBtn.innerHTML = '💾 保存';
      saveBtn.disabled = false;
    }
  }

  // Download the saved Excel, refilling with pingauge + weight + OK
  async function downloadWithExtras(metaId, filename, lotNumber, inspectionDate) {
    const dlBtn = document.getElementById(`dl-btn-${metaId}`);
    dlBtn.disabled = true;
    dlBtn.innerHTML = '<span class="loading-spinner"></span>';

    try {
      // 1. Get the current tuika record to read pingauge
      const metaRes = await fetch(`/api/tuika/${metaId}/meta`);
      const metaData = await metaRes.json();
      if (!metaData.success) throw new Error(metaData.error);

      const pingauge = metaData.file.pingauge || '';
      if (!pingauge) {
        showAlert('ピンゲージ値が未入力です。✏️ ピンゲージボタンから入力・保存してください。', 'warning');
        dlBtn.disabled = false;
        dlBtn.innerHTML = '⬇️ ダウンロード';
        return;
      }

      // 2. Get weight from inspections via lot_number
      const fileNum = extractLotFileNumber(lotNumber);
      let weight = null;
      if (fileNum) {
        const wRes = await fetch(`/api/weight-lookup?filename=${encodeURIComponent(fileNum + '.txt')}`);
        const wData = await wRes.json();
        if (wData.success && wData.weight !== null) weight = wData.weight;
      }

      // 3. Download the stored Excel file
      const excelRes = await fetch(`/api/tuika/download/${metaId}`);
      if (!excelRes.ok) throw new Error('ファイルの取得に失敗しました');
      const arrayBuffer = await excelRes.arrayBuffer();

      // 4. Load workbook and inject B4/B5/B6
      const workbook = new ExcelJS.Workbook();
      await workbook.xlsx.load(arrayBuffer);
      let ws = workbook.getWorksheet('sheet');
      if (!ws) ws = workbook.worksheets.length > 1 ? workbook.worksheets[1] : workbook.worksheets[0];

      ws.getCell('B4').value = pingauge;
      ws.getCell('B5').value = weight !== null ? weight : '';
      ws.getCell('B6').value = 'OK';

      // 5. Export
      const buffer = await workbook.xlsx.writeBuffer();
      const blob = new Blob([buffer], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      a.click();
      window.URL.revokeObjectURL(url);

      showAlert(`ダウンロード完了: ${filename} (ピンゲージ: ${pingauge}, 重量: ${weight !== null ? weight + 'g' : '未登録'})`, 'success');
    } catch (err) {
      showAlert(`ダウンロードエラー: ${err.message}`, 'error');
    } finally {
      dlBtn.disabled = false;
      dlBtn.innerHTML = '⬇️ ダウンロード';
    }
  }

  // Extract leading file number from lot_number e.g. "LOT498(498-516)" → "498"
  function extractLotFileNumber(lotNumber) {
    if (!lotNumber) return null;
    const m = String(lotNumber).match(/\((\d+)/);
    if (m) return m[1];
    const m2 = String(lotNumber).match(/\d+/);
    return m2 ? m2[0] : null;
  }

  async function deleteFile(metaId) {
    if (!confirm('このファイルをクラウドから削除しますか？')) return;
    try {
      const res = await fetch(`/api/tuika/${metaId}`, { method: 'DELETE' });
      const data = await res.json();
      if (data.success) {
        document.getElementById(`row-${metaId}`)?.remove();
        showAlert('ファイルを削除しました', 'success');
        const listEl = document.getElementById('savedFilesList');
        if (!listEl.querySelector('.file-row')) {
          listEl.innerHTML = '<div class="empty-state">保存されたファイルはありません</div>';
          document.getElementById('fileCount').textContent = '';
        }
      } else { showAlert(`削除エラー: ${data.error}`, 'error'); }
    } catch (err) { showAlert(`削除エラー: ${err.message}`, 'error'); }
  }

  function formatDate(s) {
    if (!s) return '';
    const d = new Date(s);
    return `${d.getFullYear()}/${String(d.getMonth()+1).padStart(2,'0')}/${String(d.getDate()).padStart(2,'0')} ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
  }

  // ===== UPLOAD & PROCESS (unchanged logic, now saves automatically) =====

  const dropZone = document.getElementById('dropZone');
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('drag-over'); if (e.dataTransfer.files[0]) loadFile(e.dataTransfer.files[0]); });
  document.getElementById('dataFile').addEventListener('change', e => { if (e.target.files[0]) loadFile(e.target.files[0]); });

  function loadFile(file) {
    const reader = new FileReader();
    reader.onload = e => {
      parsedData = parseData(e.target.result);
      if (parsedData && parsedData.length > 0) {
        const { distanceVals, intCircleVals } = extractTargetValues(parsedData);
        distanceValues  = distanceVals;
        intCircleValues = intCircleVals;
        document.getElementById('dataNameText').textContent = `ファイル: ${file.name}`;
        document.getElementById('dataName').style.display = 'block';
        document.getElementById('recordCount').textContent   = parsedData.length;
        document.getElementById('distanceCount').textContent  = distanceValues.length;
        document.getElementById('intCircleCount').textContent = intCircleValues.length;
        document.getElementById('statsContainer').style.display = 'block';
        showAlert(`${parsedData.length}件のレコードを抽出しました`, 'success');
      } else {
        showAlert('ファイルの形式が正しくないか、データが含まれていません', 'error');
      }
    };
    reader.readAsText(file);
  }

  function parseData(content) {
    const data = [];
    for (const line of content.split('\n')) {
      if (!line.trim()) continue;
      const parts = line.trim().split(';');
      if (parts.length < 2) continue;
      const row = { ID: parts[0], Type: parts[1] };
      const vals = parts.slice(2).map(p => p.trim());
      let cols = [];
      if (parts[1]==='PLANE') cols=['Method','X','Y','Z','A','B','C','','D','Dev'];
      else if (parts[1]==='CIRCLE') cols=['Method','X','Y','Z','I','J','K','','Radius','Dev'];
      else if (parts[1]==='PT-COMP') cols=['Method','X','Y','Z'];
      else if (parts[1]==='DISTANCE') cols=['','X','Y','Z','','','','','Distance'];
      else if (parts[1]==='CONE') cols=['Method','X','Y','Z','I','J','K','','Half-Angle','Dev'];
      else if (parts[1]==='INT-CIRCLE') cols=['','X','Y','Z','I','J','K','','Radius'];
      else if (parts[1]==='SYM-POINT') cols=['','X','Y','Z'];
      for (let i=0;i<vals.length;i++) if (i<cols.length&&cols[i]&&vals[i]) row[cols[i]]=/^-?\d+\.?\d*$/.test(vals[i])?parseFloat(vals[i]):vals[i];
      data.push(row);
    }
    return data;
  }

  function extractTargetValues(data) {
    const distItems=[], intCircleVals=[];
    for (const item of data) {
      if (item.Type==='DISTANCE'&&item.X!==undefined) distItems.push({id:item.ID,value:Math.round(Math.abs(item.X)*100)/100});
      else if (item.Type==='INT-CIRCLE'&&item.Radius!==undefined) intCircleVals.push(Math.round(item.Radius*100)/100);
    }
    const distanceVals=[];
    for (const t of ['3','2','1','4']) for (const item of distItems) if (String(item.id)===t){distanceVals.push(item.value);break;}
    return {distanceVals,intCircleVals};
  }

  function extractLotPrefix(lot) {
    if (!lot) return null;
    const m = String(lot).match(/^([A-Za-z]*)(\d+)/);
    if (!m) return String(lot);
    return ((m[1].toUpperCase().includes('LOT') ? m[1].toUpperCase() : 'LOT') + m[2]);
  }

  function validateDateFormat(d) { return d && /^\d{4}\/\d{2}\/\d{2}$/.test(d); }
  function formatDateForFilename(d) { return String(d).replace(/\//g,'').replace(/-/g,'').substring(0,8); }

  function loadDefaultTemplate() {
    const paths=['/public/templates/LOT_template.xlsx','/templates/LOT_template.xlsx','LOT_template.xlsx'];
    return tryPath(paths,0);
  }
  function tryPath(paths,i) {
    if (i>=paths.length){showAlert('テンプレートが見つかりません','error');return Promise.resolve(null);}
    return fetch(paths[i]).then(r=>r.ok?r.arrayBuffer():tryPath(paths,i+1)).catch(()=>tryPath(paths,i+1));
  }

  // Process → generate Excel → save to cloud (no pingauge at this stage)
  function processData() {
    const lotNumber      = document.getElementById('lotNumber').value.trim();
    const inspectionDate = document.getElementById('inspectionDate').value.trim();

    if (!parsedData)   { showAlert('測定データファイルを読み込んでください','error'); return; }
    if (!lotNumber || !inspectionDate) { showAlert('LOT番号と検査日を入力してください','error'); return; }
    if (!validateDateFormat(inspectionDate)) { showAlert('検査日の形式が正しくありません (YYYY/MM/DD)','error'); return; }

    const btn = document.getElementById('processBtn');
    btn.disabled=true; btn.innerHTML='<span class="loading-spinner"></span> 処理中...';

    loadDefaultTemplate().then(async ab => {
      if (!ab){btn.disabled=false;btn.innerHTML='📊 Excel を生成 &amp; 保存';return;}
      try {
        const workbook = new ExcelJS.Workbook();
        await workbook.xlsx.load(ab);
        let ws = workbook.getWorksheet('sheet');
        if (!ws) ws = workbook.worksheets.length>1?workbook.worksheets[1]:workbook.worksheets[0];

        // Fill standard cells (B4/B5/B6 left empty — filled at download time)
        const lotPrefix = extractLotPrefix(lotNumber);
        ws.getCell('B1').value = lotNumber;
        ws.getCell('B2').value = inspectionDate;
        if (lotPrefix) ws.getCell('B3').value = lotPrefix;
        // B4, B5, B6 intentionally blank here — filled when user downloads

        for (let i=0;i<distanceValues.length;i++)  ws.getCell(`A${i+1}`).value=distanceValues[i];
        for (let i=0;i<intCircleValues.length;i++) ws.getCell(`A${distanceValues.length+i+1}`).value=intCircleValues[i];

        processedWorkbook = workbook;
        exportFilename = `水平ノズル${lotNumber}全箇所測定-${formatDateForFilename(inspectionDate)}.xlsx`;

        // Save to cloud
        const buffer = await workbook.xlsx.writeBuffer();
        const base64 = btoa(String.fromCharCode(...new Uint8Array(buffer)));

        const res = await fetch('/api/tuika/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            filename: exportFilename,
            lotNumber,
            inspectionDate,
            pingauge: '',   // empty at this stage
            fileData: base64
          })
        });
        const saveData = await res.json();
        if (!saveData.success) throw new Error(saveData.error);

        document.getElementById('fileInfo').textContent = `保存完了: ${exportFilename}`;
        btn.disabled=false; btn.innerHTML='✅ 保存完了';
        document.getElementById('downloadContainer').style.display='block';
        showAlert('クラウドへ保存しました。一覧からピンゲージ値を入力してDLしてください。','success');

        // Auto-open saved files panel and refresh
        savedFilesLoaded = false;
        if (!savedFilesOpen) toggleSavedFiles();
        else loadSavedFiles();

      } catch(err){
        showAlert(`エラー: ${err.message}`,'error');
        btn.disabled=false; btn.innerHTML='📊 Excel を生成 &amp; 保存';
      }
    });
  }

  function resetForm() {
    parsedData=null; distanceValues=[]; intCircleValues=[]; processedWorkbook=null; exportFilename=null;
    document.getElementById('dataFile').value='';
    document.getElementById('lotNumber').value='';
    document.getElementById('inspectionDate').value='';
    ['dataName','statsContainer','downloadContainer'].forEach(id=>document.getElementById(id).style.display='none');
    const btn=document.getElementById('processBtn');
    btn.disabled=false; btn.innerHTML='📊 Excel を生成 &amp; 保存';
    showAlert('フォームをリセットしました','info');
  }

  function showAlert(message,type) {
    const c=document.getElementById('alertContainer');
    const d=document.createElement('div');
    d.className=`alert-box alert-${type}`;
    const icons={'success':'✓','error':'✕','info':'ℹ','warning':'⚠'};
    d.innerHTML=`<div class="alert-icon">${icons[type]||'ℹ'}</div><div class="alert-content">${message}</div>`;
    c.innerHTML=''; c.appendChild(d);
    setTimeout(()=>d.remove(),6000);
  }

  // Auto-open the saved files panel on page load
  window.addEventListener('load', () => {
    toggleSavedFiles();
  });
</script>
</body>
</html>
