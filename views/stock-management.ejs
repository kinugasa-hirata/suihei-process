<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>在庫管理 - Stock Management</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
  <style>
    body { background-color: #f5f5f5; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .container { max-width: 1400px; margin-top: 2rem; padding-bottom: 3rem; }
    .header-section {
      background: white; border-radius: 12px; padding: 2rem; margin-bottom: 2rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1); display: flex;
      justify-content: space-between; align-items: center;
    }
    .header-title { font-size: 2rem; font-weight: 700; color: #2c3e50; margin-bottom: 0.5rem; }
    .header-subtitle { color: #7f8c8d; font-size: 1.1rem; }
    .nav-tabs-custom { border-bottom: 3px solid #e9ecef; margin-bottom: 2rem; }
    .nav-tabs-custom .nav-link {
      color: #6c757d; font-weight: 600; border: none; padding: 1rem 2rem; transition: all 0.3s;
    }
    .nav-tabs-custom .nav-link:hover { color: #0d6efd; border-color: transparent; }
    .nav-tabs-custom .nav-link.active {
      color: #0d6efd; border: none; border-bottom: 3px solid #0d6efd; background: transparent;
    }
    .section-card {
      background: white; border-radius: 12px; padding: 2rem; margin-bottom: 2rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .section-title {
      font-size: 1.5rem; font-weight: 700; color: #2c3e50;
      margin-bottom: 1.5rem; padding-bottom: 0.5rem; border-bottom: 2px solid #e9ecef;
    }
    .table-responsive { border-radius: 8px; overflow: hidden; }
    .custom-table { margin-bottom: 0; }
    .custom-table thead { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }
    .custom-table thead th { padding: 1rem; font-weight: 600; border: none; }
    .custom-table tbody td { padding: 1rem; vertical-align: middle; }
    .custom-table tbody tr:hover { background-color: #f8f9fa; }
    .empty-state { text-align: center; padding: 3rem; color: #6c757d; }
    .empty-state .material-icons { font-size: 4rem; color: #dee2e6; margin-bottom: 1rem; }
    .modal-backdrop-custom {
      display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.5); z-index: 9998;
    }
    .modal-backdrop-custom.show { display: block; }
    .modal-custom {
      display: none; position: fixed; top: 50%; left: 50%;
      transform: translate(-50%, -50%); background: white; border-radius: 12px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.3); z-index: 9999;
      max-width: 640px; width: 90%; max-height: 90vh; overflow-y: auto;
    }
    .modal-custom.show { display: block; }
    .modal-header-custom {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white; padding: 1.5rem; border-radius: 12px 12px 0 0;
    }
    .modal-body-custom { padding: 2rem; }
    .form-label-custom { font-weight: 600; color: #2c3e50; margin-bottom: 0.5rem; }
    .material-icons {
      font-family: 'Material Icons'; font-weight: normal; font-style: normal;
      font-size: 24px; display: inline-block; line-height: 1;
    }
    .chip {
      display: inline-block; background: #e9ecef; border-radius: 4px;
      padding: 1px 7px; font-size: 0.78rem; margin: 2px;
    }
    .chip-blue {
      background: #e2f0fb; border: 1px solid #9ec5fe;
      border-radius: 4px; padding: 1px 8px; font-size: 0.8rem;
      margin: 2px; color: #084298; display: inline-block;
    }

    /* ── Lifecycle flow diagram ── */
    .lifecycle-flow {
      display: flex; align-items: center; gap: 0; flex-wrap: nowrap;
      overflow-x: auto; padding: 1rem 0;
    }
    .lf-step {
      display: flex; flex-direction: column; align-items: center;
      min-width: 130px; padding: 0.75rem 0.5rem;
      border-radius: 8px; font-size: 0.82rem; text-align: center;
    }
    .lf-arrow {
      font-size: 1.4rem; color: #adb5bd; flex-shrink: 0; margin: 0 4px;
      align-self: center;
    }
    .lf-trigger {
      font-size: 0.72rem; color: #6c757d; margin-top: 4px; font-style: italic;
    }
  </style>
</head>
<body>
<div class="container">

  <!-- Header -->
  <div class="header-section">
    <div>
      <div class="header-title">在庫管理システム</div>
      <div class="header-subtitle">Stock Management System — Orders, Imports &amp; Inventory</div>
    </div>
    <div style="display:flex;gap:0.75rem;align-items:center;">
      <a href="/" class="btn btn-outline-secondary" style="display:flex;align-items:center;gap:6px;">
        <span class="material-icons" style="font-size:18px;">home</span> ホーム
      </a>
      <button class="btn btn-outline-primary" style="display:flex;align-items:center;gap:6px;"
              onclick="document.getElementById('lifecycleModal').classList.add('show'); document.getElementById('lifecycleModalBackdrop').classList.add('show');">
        <span class="material-icons" style="font-size:18px;">info</span> ステータス説明
      </button>
    </div>
  </div>

  <!-- Tabs -->
  <ul class="nav nav-tabs-custom" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active" id="orders-tab" data-bs-toggle="tab" data-bs-target="#orders"
        type="button" role="tab">
        <span class="material-icons" style="vertical-align:middle;margin-right:0.5rem;">shopping_cart</span>
        注文管理 (Orders)
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="imports-tab" data-bs-toggle="tab" data-bs-target="#imports"
        type="button" role="tab">
        <span class="material-icons" style="vertical-align:middle;margin-right:0.5rem;">local_shipping</span>
        入荷管理 (Imports)
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="inventory-tab" data-bs-toggle="tab" data-bs-target="#inventory"
        type="button" role="tab">
        <span class="material-icons" style="vertical-align:middle;margin-right:0.5rem;">inventory_2</span>
        在庫状況 (Inventory)
      </button>
    </li>
  </ul>

  <!-- Tab Content -->
  <div class="tab-content">

    <!-- ══════════════════════════════════════════
         ORDERS TAB
         ══════════════════════════════════════════ -->
    <div class="tab-pane fade show active" id="orders" role="tabpanel">
      <div class="section-card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
          <h2 class="section-title" style="margin-bottom:0;">注文一覧 (Order List)</h2>
          <button class="btn btn-primary" onclick="openOrderModal()"
            style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);border:none;">
            <span class="material-icons" style="vertical-align:middle;">add</span> 新規注文
          </button>
        </div>
        <div id="ordersEmpty" class="empty-state" style="display:none;">
          <span class="material-icons">inbox</span>
          <p>注文がまだ登録されていません</p>
        </div>
        <div class="table-responsive">
          <table class="table custom-table" id="ordersTable" style="display:none;">
            <thead>
              <tr>
                <th>注文日</th>
                <th>数量</th>
                <th>納期</th>
                <th>ステータス</th>
                <th>在庫状況</th>
                <th>割当製品</th>
                <th>操作</th>
              </tr>
            </thead>
            <tbody id="ordersList"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════
         IMPORTS TAB  (scheduled only)
         ══════════════════════════════════════════ -->
    <div class="tab-pane fade" id="imports" role="tabpanel">
      <div class="section-card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
          <h2 class="section-title" style="margin-bottom:0;">
            入荷管理
            <small style="font-size:0.8rem;color:#6c757d;font-weight:400;">（入荷予定のみ表示）</small>
          </h2>
          <button class="btn btn-primary" onclick="openImportModal()"
            style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);border:none;">
            <span class="material-icons" style="vertical-align:middle;">add</span> 新規入荷
          </button>
        </div>
        <div id="importsEmpty" class="empty-state" style="display:none;">
          <span class="material-icons">local_shipping</span>
          <p>入荷予定がありません</p>
        </div>
        <div class="table-responsive">
          <table class="table custom-table" id="importsTable" style="display:none;">
            <thead>
              <tr>
                <th>登録日</th>
                <th>数量</th>
                <th>予定日</th>
                <th>ステータス</th>
                <th>製品番号</th>
                <th>操作</th>
              </tr>
            </thead>
            <tbody id="importsList"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════
         INVENTORY TAB
         ══════════════════════════════════════════ -->
    <div class="tab-pane fade" id="inventory" role="tabpanel">
      <div class="section-card">
        <h2 class="section-title">在庫状況 (Inventory)</h2>
        <div id="inventoryContent">
          <div style="text-align:center;padding:2rem;color:#6c757d;"><p>読み込み中...</p></div>
        </div>
      </div>
    </div>

  </div><!-- /tab-content -->
</div><!-- /container -->

<!-- ══════════ LIFECYCLE INFO MODAL ══════════ -->
<div class="modal-backdrop-custom" id="lifecycleModalBackdrop"
     onclick="document.getElementById('lifecycleModal').classList.remove('show'); this.classList.remove('show');"></div>
<div class="modal-custom" id="lifecycleModal" style="max-width:700px;">
  <div class="modal-header-custom" style="display:flex;justify-content:space-between;align-items:center;">
    <h3 style="margin:0;">
      <span class="material-icons" style="vertical-align:middle;margin-right:0.5rem;">info</span>
      ステータスの自動変化フロー
    </h3>
    <button onclick="document.getElementById('lifecycleModal').classList.remove('show'); document.getElementById('lifecycleModalBackdrop').classList.remove('show');"
            style="background:none;border:none;color:white;font-size:1.5rem;cursor:pointer;line-height:1;">×</button>
  </div>
  <div class="modal-body-custom">

    <!-- Flow diagram -->
    <div class="lifecycle-flow">
      <div class="lf-step" style="background:#f8f9fa;border:2px dashed #adb5bd;color:#495057;">
        <span style="font-size:1.5rem;">📦</span>
        <strong style="margin-top:4px;">入荷予定</strong>
        <span class="lf-trigger">新規入荷登録時<br>自動作成</span>
      </div>
      <div class="lf-arrow">→</div>
      <div class="lf-step" style="background:#e2f0fb;border:2px solid #6ea8fe;color:#084298;">
        <span style="font-size:1.5rem;">🚚</span>
        <strong style="margin-top:4px;">入荷済</strong>
        <span class="lf-trigger">「入荷確認」ボタン<br>を押した時</span>
      </div>
      <div class="lf-arrow">→</div>
      <div class="lf-step" style="background:#fffdf0;border:2px dashed #e6a817;color:#664d03;">
        <span style="font-size:1.5rem;">🔬</span>
        <strong style="margin-top:4px;">検査中</strong>
        <span class="lf-trigger">TXTファイル<br>アップロード時</span>
      </div>
      <div class="lf-arrow">→</div>
      <div class="lf-step" style="background:#f6fff9;border:2px solid #198754;color:#0f5132;">
        <span style="font-size:1.5rem;">✅</span>
        <strong style="margin-top:4px;">検査完了</strong>
        <span class="lf-trigger">重量入力・保存時<br>（自動昇格）</span>
      </div>
      <div class="lf-arrow">→</div>
      <div class="lf-step" style="background:#f0f0f0;border:2px solid #6c757d;color:#343a40;">
        <span style="font-size:1.5rem;">🚢</span>
        <strong style="margin-top:4px;">出荷済</strong>
        <span class="lf-trigger">「出荷」ボタン<br>を押した時</span>
      </div>
    </div>

    <hr style="margin:1.5rem 0;">

    <!-- Status table -->
    <table class="table table-sm" style="font-size:0.88rem;">
      <thead style="background:#f8f9fa;">
        <tr>
          <th>ステータス</th>
          <th>意味</th>
          <th>自動変化トリガー</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><span style="background:#f8f9fa;border:2px dashed #adb5bd;border-radius:4px;padding:2px 8px;font-size:0.8rem;">入荷予定</span></td>
          <td>発注済・未着荷。製品番号はこの時点で確定する</td>
          <td>新規入荷登録時に自動生成される</td>
        </tr>
        <tr>
          <td><span style="background:#e2f0fb;border:1px solid #6ea8fe;border-radius:4px;padding:2px 8px;font-size:0.8rem;color:#084298;">入荷済</span></td>
          <td>物理的に届いた。まだ検査前</td>
          <td>入荷管理の「入荷確認」ボタン</td>
        </tr>
        <tr>
          <td><span style="background:#fff3cd;border:1px solid #e6a817;border-radius:4px;padding:2px 8px;font-size:0.8rem;color:#664d03;">検査中</span></td>
          <td>3D測定データ取り込み済。重量未設定</td>
          <td>TXTファイルのアップロード</td>
        </tr>
        <tr>
          <td><span style="background:#d1e7dd;border:1px solid #198754;border-radius:4px;padding:2px 8px;font-size:0.8rem;color:#0f5132;">検査完了</span></td>
          <td>重量入力済。出荷可能な状態</td>
          <td>重量値を入力して保存ボタンを押す</td>
        </tr>
        <tr>
          <td><span style="background:#e9ecef;border:1px solid #6c757d;border-radius:4px;padding:2px 8px;font-size:0.8rem;color:#343a40;">出荷済</span></td>
          <td>注文に割り当てられ出荷完了。画面から消える</td>
          <td>注文の「出荷」ボタン</td>
        </tr>
      </tbody>
    </table>

    <div class="alert alert-info py-2 px-3" style="font-size:0.83rem;margin-top:1rem;">
      <strong>💡 注文ステータスは自動計算されます：</strong><br>
      割り当て製品がすべて検査完了 → <strong style="color:#198754;">完了</strong> ／
      一部検査中 → <strong style="color:#0d6efd;">処理中</strong> ／
      在庫不足・入荷待ち → <strong style="color:#e6a817;">保留中</strong>
    </div>

    <button class="btn btn-secondary w-100" style="margin-top:0.5rem;"
      onclick="document.getElementById('lifecycleModal').classList.remove('show'); document.getElementById('lifecycleModalBackdrop').classList.remove('show');">
      閉じる
    </button>
  </div>
</div>

<!-- ══════════ ORDER MODAL ══════════ -->
<div class="modal-backdrop-custom" id="orderModalBackdrop" onclick="closeOrderModal()"></div>
<div class="modal-custom" id="orderModal">
  <div class="modal-header-custom">
    <h3 style="margin:0;">注文管理</h3>
  </div>
  <div class="modal-body-custom">
    <form id="orderForm">
      <input type="hidden" id="orderId" name="orderId">
      <div class="mb-3">
        <label for="quantity" class="form-label form-label-custom">数量</label>
        <input type="number" class="form-control" id="quantity" name="quantity" min="1" required>
      </div>
      <div class="mb-3">
        <label for="dueDate" class="form-label form-label-custom">納期</label>
        <input type="date" class="form-control" id="dueDate" name="due_date" required>
      </div>
      <div class="alert alert-info py-2 px-3" style="font-size:0.85rem;">
        <strong>ステータスは自動計算：</strong>
        在庫充足 → <span style="color:#198754;font-weight:600;">完了</span> ／
        一部準備中 → <span style="color:#0d6efd;font-weight:600;">処理中</span> ／
        在庫待ち → <span style="color:#e6a817;font-weight:600;">保留中</span>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success flex-grow-1">保存</button>
        <button type="button" class="btn btn-secondary" onclick="closeOrderModal()">キャンセル</button>
        <button type="button" class="btn btn-danger" id="cancelOrderBtn" style="display:none;" onclick="cancelCurrentOrder()">注文キャンセル</button>
      </div>
    </form>
  </div>
</div>

<!-- ══════════ IMPORT MODAL ══════════ -->
<div class="modal-backdrop-custom" id="importModalBackdrop" onclick="closeImportModal()"></div>
<div class="modal-custom" id="importModal">
  <div class="modal-header-custom">
    <h3 style="margin:0;">入荷管理</h3>
  </div>
  <div class="modal-body-custom">
    <form id="importForm">
      <input type="hidden" id="importId" name="importId">
      <div class="mb-3">
        <label for="importQuantity" class="form-label form-label-custom">数量</label>
        <input type="number" class="form-control" id="importQuantity" name="quantity" min="1" required>
      </div>
      <div class="mb-3">
        <label for="scheduledDate" class="form-label form-label-custom">予定日</label>
        <input type="date" class="form-control" id="scheduledDate" name="scheduled_date" required>
      </div>
      <div class="mb-3">
        <label for="actualDate" class="form-label form-label-custom">実際の入荷日</label>
        <input type="date" class="form-control" id="actualDate" name="actual_date">
      </div>
      <div class="mb-3">
        <label for="importStatus" class="form-label form-label-custom">ステータス</label>
        <select class="form-select" id="importStatus" name="status">
          <option value="scheduled">予定</option>
          <option value="arrived">入荷済</option>
        </select>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success flex-grow-1">保存</button>
        <button type="button" class="btn btn-secondary" onclick="closeImportModal()">キャンセル</button>
      </div>
    </form>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ══════════════════════════════════════════════════════════════
// ORDER MODAL
// ══════════════════════════════════════════════════════════════
let _editingOrderId = null;

function openOrderModal(orderId = null) {
  _editingOrderId = orderId;
  const cancelBtn = document.getElementById('cancelOrderBtn');
  if (orderId) {
    fetch(`/api/orders/${orderId}`)
      .then(r => r.json())
      .then(data => {
        document.getElementById('orderId').value = data.$id;
        document.getElementById('quantity').value = data.quantity;
        document.getElementById('dueDate').value = data.due_date
          ? data.due_date.substring(0, 10) : '';
      });
    cancelBtn.style.display = '';
  } else {
    document.getElementById('orderForm').reset();
    document.getElementById('orderId').value = '';
    cancelBtn.style.display = 'none';
  }
  document.getElementById('orderModalBackdrop').classList.add('show');
  document.getElementById('orderModal').classList.add('show');
}
function closeOrderModal() {
  document.getElementById('orderModalBackdrop').classList.remove('show');
  document.getElementById('orderModal').classList.remove('show');
}
function editOrder(orderId) { openOrderModal(orderId); }

async function cancelCurrentOrder() {
  if (!_editingOrderId) return;
  if (!confirm('この注文をキャンセルしますか？')) return;
  try {
    const r = await fetch(`/api/orders/${_editingOrderId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: 'cancelled' })
    });
    const res = await r.json();
    if (res.success) { closeOrderModal(); location.reload(); }
    else alert('エラー: ' + res.error);
  } catch(err) { alert('エラー: ' + err.message); }
}

async function deleteOrder(orderId) {
  if (!confirm('この注文を削除しますか？')) return;
  try {
    const r = await fetch(`/api/orders/${orderId}`, { method: 'DELETE' });
    const res = await r.json();
    if (res.success) location.reload();
    else alert('削除エラー: ' + res.error);
  } catch(err) { alert('エラー: ' + err.message); }
}

document.getElementById('orderForm').addEventListener('submit', async e => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const orderId = fd.get('orderId');
  // Status intentionally NOT sent — computed automatically on the frontend
  const data = { quantity: fd.get('quantity'), due_date: fd.get('due_date') };
  try {
    const url    = orderId ? `/api/orders/${orderId}` : '/api/orders';
    const method = orderId ? 'PUT' : 'POST';
    const r = await fetch(url, {
      method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data)
    });
    const res = await r.json();
    if (res.success) location.reload();
    else alert('保存エラー: ' + res.error);
  } catch(err) { alert('エラー: ' + err.message); }
});

// Ship order
function shipOrderFromBtn(btn) {
  const orderId  = btn.dataset.orderId;
  const quantity = btn.dataset.quantity;
  const itemIds  = btn.dataset.itemIds ? btn.dataset.itemIds.split(',').filter(Boolean) : [];
  shipOrder(orderId, quantity, itemIds);
}
async function shipOrder(orderId, quantity, itemIds) {
  if (!itemIds || itemIds.length === 0) { alert('出荷可能な製品がありません'); return; }
  if (!confirm(`出荷処理を実行しますか？\n対象: ${itemIds.length} 個\n\n注文と製品は画面から非表示になります（データはAppwriteに保持）。`)) return;
  try {
    const r = await fetch(`/api/orders/${orderId}/ship`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ itemIds })
    });
    const res = await r.json();
    if (res.success) { alert(`出荷完了: ${res.shippedCount} 個`); location.reload(); }
    else alert('出荷エラー: ' + res.error);
  } catch(err) { alert('エラー: ' + err.message); }
}

// ══════════════════════════════════════════════════════════════
// IMPORT MODAL
// ══════════════════════════════════════════════════════════════
function openImportModal(importId = null) {
  if (importId) {
    fetch(`/api/imports/${importId}`)
      .then(r => r.json())
      .then(data => {
        document.getElementById('importId').value = data.$id;
        document.getElementById('importQuantity').value = data.quantity;
        document.getElementById('scheduledDate').value = data.scheduled_date
          ? data.scheduled_date.substring(0, 10) : '';
        document.getElementById('actualDate').value = data.actual_date
          ? data.actual_date.substring(0, 10) : '';
        document.getElementById('importStatus').value = data.status;
      });
  } else {
    document.getElementById('importForm').reset();
    document.getElementById('importId').value = '';
  }
  document.getElementById('importModalBackdrop').classList.add('show');
  document.getElementById('importModal').classList.add('show');
}
function closeImportModal() {
  document.getElementById('importModalBackdrop').classList.remove('show');
  document.getElementById('importModal').classList.remove('show');
}
function editImport(importId) { openImportModal(importId); }

async function deleteImport(importId) {
  if (!confirm('この入荷予定を削除しますか？')) return;
  try {
    const r = await fetch(`/api/imports/${importId}`, { method: 'DELETE' });
    const res = await r.json();
    if (res.success) location.reload();
    else alert('削除エラー: ' + res.error);
  } catch(err) { alert('エラー: ' + err.message); }
}

async function confirmArrival(importId, count) {
  if (!confirm(`入荷確認しますか？\n対象: ${count} 個\nステータスが「入荷済」に変わり、製品が在庫に反映されます。`)) return;
  try {
    const today = new Date().toISOString().split('T')[0];
    const r = await fetch(`/api/imports/${importId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: 'arrived', actual_date: today })
    });
    const res = await r.json();
    if (res.success) { alert(`入荷確認完了: ${count} 個`); location.reload(); }
    else alert('エラー: ' + res.error);
  } catch(err) { alert('エラー: ' + err.message); }
}

document.getElementById('importForm').addEventListener('submit', async e => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const importId = fd.get('importId');
  const data = {
    quantity:       fd.get('quantity'),
    scheduled_date: fd.get('scheduled_date'),
    actual_date:    fd.get('actual_date') || null,
    status:         fd.get('status')
  };
  try {
    const url    = importId ? `/api/imports/${importId}` : '/api/imports';
    const method = importId ? 'PUT' : 'POST';
    const r = await fetch(url, {
      method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data)
    });
    const res = await r.json();
    if (res.success) location.reload();
    else alert('保存エラー: ' + res.error);
  } catch(err) { alert('エラー: ' + err.message); }
});

// ══════════════════════════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════════════════════════
function groupByLot(docs) {
  const map = {};
  docs.forEach(d => {
    const lot = d.lot != null ? String(d.lot) : '—';
    const num = parseInt((d.filename || '').replace('.txt', '')) || 0;
    if (!map[lot]) map[lot] = { lot, nums: [], docs: [] };
    map[lot].nums.push(num);
    map[lot].docs.push(d);
  });
  return Object.values(map)
    .sort((a, b) => (parseInt(a.lot) || 0) - (parseInt(b.lot) || 0))
    .map(g => ({ ...g, nums: g.nums.sort((a, b) => a - b) }));
}

// ══════════════════════════════════════════════════════════════
// MAIN RENDER
// ══════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', function () {

  // Server-injected data
  const orders   = <%- JSON.stringify(orders) %>;
  const imports  = <%- JSON.stringify(imports) %>;
  const byStatus = <%- JSON.stringify(inspectionsByStatus) %>;

  // ─────────────────────────────────────────────────────────────
  // BUILD FLAT INVENTORY
  // Priority: finished_inspection(0) > inspection(1) > imported(2) > upcoming_import(3)
  // NO minFileNum filter — shipped records are already excluded by the server query.
  // Products that have been shipped are status='shipped' and never appear in byStatus.
  // ─────────────────────────────────────────────────────────────
  const INV_PRIORITY = ['finished_inspection', 'inspection', 'imported', 'upcoming_import'];
  const flatInventory = [];
  INV_PRIORITY.forEach((st, pri) => {
    (byStatus[st] || []).forEach(d => {
      const n = parseInt((d.filename || '').replace('.txt', '')) || 0;
      flatInventory.push({ ...d, _num: n, _pri: pri });
    });
  });
  // Sort: highest-priority first, then lowest number first (FIFO within same priority)
  flatInventory.sort((a, b) => a._pri !== b._pri ? a._pri - b._pri : a._num - b._num);

  // ─────────────────────────────────────────────────────────────
  // ALLOCATE INVENTORY TO ORDERS  (earliest due date wins)
  // ─────────────────────────────────────────────────────────────
  const activeOrders = orders.filter(o => o.status !== 'cancelled' && o.status !== 'shipped');
  const ordersByDue  = [...activeOrders].sort((a, b) => new Date(a.due_date) - new Date(b.due_date));

  const takenIds = new Set();
  const reAlloc  = {}; // orderId → items[]
  ordersByDue.forEach(o => {
    const qty    = parseInt(o.quantity) || 0;
    const picked = [];
    for (const item of flatInventory) {
      if (!takenIds.has(item.$id) && picked.length < qty) {
        picked.push(item);
        takenIds.add(item.$id);
      }
    }
    reAlloc[o.$id] = picked;
  });

  // ─────────────────────────────────────────────────────────────
  // COMPUTE AUTO-STATUS FOR EACH ORDER
  //   完了   = all needed slots are finished_inspection
  //   処理中  = some items allocated but not all finished yet
  //   保留中  = not enough stock at all
  //   cancelled / shipped handled separately
  // ─────────────────────────────────────────────────────────────
  function computeAutoStatus(order, items) {
    const needed     = parseInt(order.quantity) || 0;
    const readyCount = items.filter(i => i.status === 'finished_inspection').length;

    if (readyCount >= needed)
      return { key: 'completed',  label: '完了',   bg: '#198754' };
    if (items.some(i => i.status === 'inspection' || i.status === 'imported') || readyCount > 0)
      return { key: 'processing', label: '処理中', bg: '#0d6efd' };
    return { key: 'pending',    label: '保留中', bg: '#e6a817' };
  }

  // ─────────────────────────────────────────────────────────────
  // RENDER ORDERS TABLE
  // ─────────────────────────────────────────────────────────────
  const ordersList  = document.getElementById('ordersList');
  const ordersTable = document.getElementById('ordersTable');
  const ordersEmpty = document.getElementById('ordersEmpty');

  // Display: all non-shipped orders. Cancelled at bottom, active sorted by due date.
  const allDisplayOrders = orders.filter(o => o.status !== 'shipped');
  allDisplayOrders.sort((a, b) => {
    if (a.status === 'cancelled' && b.status !== 'cancelled') return 1;
    if (b.status === 'cancelled' && a.status !== 'cancelled') return -1;
    return new Date(a.due_date) - new Date(b.due_date);
  });

  if (allDisplayOrders.length > 0) {
    ordersTable.style.display = '';
    ordersEmpty.style.display = 'none';

    allDisplayOrders.forEach(o => {
      const isCancelled = o.status === 'cancelled';
      const items       = isCancelled ? [] : (reAlloc[o.$id] || []);
      const needed      = parseInt(o.quantity) || 0;
      const readyItems  = items.filter(i => i.status === 'finished_inspection');
      const readyCount  = readyItems.length;
      const itemIds     = readyItems.map(i => i.$id).join(',');

      const autoStatus = isCancelled
        ? { key: 'cancelled', label: 'キャンセル', bg: '#dc3545' }
        : computeAutoStatus(o, items);

      // Stock availability badge
      let stockBg, stockLabel;
      if (isCancelled) {
        stockBg = '#6c757d'; stockLabel = '—';
      } else if (items.length === 0) {
        stockBg = '#dc3545'; stockLabel = '在庫なし';
      } else if (readyCount >= needed) {
        stockBg = '#198754'; stockLabel = `出荷可能 (${needed})`;
      } else if (readyCount > 0) {
        stockBg = '#fd7e14'; stockLabel = `一部完了 (${readyCount}/${needed})`;
      } else if (items.some(i => i.status === 'inspection' || i.status === 'imported')) {
        stockBg = '#0d6efd'; stockLabel = `検査中 (0/${needed})`;
      } else {
        stockBg = '#e6a817'; stockLabel = `入荷待ち (0/${needed})`;
      }

      const dueDate   = o.due_date   ? new Date(o.due_date).toLocaleDateString('ja-JP')   : '—';
      const createdAt = o.$createdAt ? new Date(o.$createdAt).toLocaleDateString('ja-JP') : '—';

      // Show all allocated items (not just ready ones) as chips
      const chips = items.map(i => {
        const chipColor = i.status === 'finished_inspection' ? '#198754'
                        : i.status === 'inspection'          ? '#e6a817'
                        : i.status === 'imported'            ? '#0d6efd'
                        : '#adb5bd';
        return `<span class="chip" style="border:1px solid ${chipColor};color:${chipColor};">${i._num}</span>`;
      }).join('');

      const canShip  = !isCancelled && readyCount > 0;
      const rowStyle = isCancelled ? 'opacity:0.55;' : '';

      ordersList.insertAdjacentHTML('beforeend', `
        <tr style="${rowStyle}">
          <td style="white-space:nowrap;">${createdAt}</td>
          <td>${needed}</td>
          <td style="white-space:nowrap;">${dueDate}</td>
          <td>
            <span style="background:${autoStatus.bg};color:white;padding:2px 10px;border-radius:12px;font-size:0.8rem;font-weight:600;">
              ${autoStatus.label}
            </span>
          </td>
          <td>
            <span style="background:${stockBg};color:white;padding:2px 10px;border-radius:12px;font-size:0.8rem;white-space:nowrap;font-weight:600;">
              ${stockLabel}
            </span>
          </td>
          <td style="line-height:1.8;max-width:340px;">${chips || '<em style="color:#aaa;font-size:0.8rem;">—</em>'}</td>
          <td style="white-space:nowrap;">
            ${!isCancelled ? `<button class="btn btn-sm btn-outline-primary me-1" onclick="editOrder('${o.$id}')">編集</button>` : ''}
            <button class="btn btn-sm btn-outline-danger me-1" onclick="deleteOrder('${o.$id}')">削除</button>
            ${canShip ? `
              <button class="btn btn-sm btn-success"
                data-order-id="${o.$id}"
                data-quantity="${o.quantity}"
                data-item-ids="${itemIds}"
                onclick="shipOrderFromBtn(this)"
                style="background:#198754;border:none;">
                🚚 出荷
              </button>` : ''}
          </td>
        </tr>`);
    });
  } else {
    ordersTable.style.display = 'none';
    ordersEmpty.style.display = '';
  }

  // ─────────────────────────────────────────────────────────────
  // RENDER IMPORTS TABLE (scheduled only)
  // ─────────────────────────────────────────────────────────────
  const importsList  = document.getElementById('importsList');
  const importsTable = document.getElementById('importsTable');
  const importsEmpty = document.getElementById('importsEmpty');

  // Build importId → linked file numbers from inspection records
  const importLinkedNums = {};
  Object.values(byStatus).forEach(docs => {
    docs.forEach(d => {
      if (!d.import_id) return;
      if (!importLinkedNums[d.import_id]) importLinkedNums[d.import_id] = [];
      const n = parseInt((d.filename || '').replace('.txt', '')) || 0;
      if (n > 0) importLinkedNums[d.import_id].push(n);
    });
  });
  Object.values(importLinkedNums).forEach(arr => arr.sort((a, b) => a - b));

  // Fallback to import's own linked_files field
  imports.forEach(imp => {
    if (!importLinkedNums[imp.$id] && imp.linked_files && imp.linked_files.length > 0) {
      importLinkedNums[imp.$id] = imp.linked_files
        .map(f => parseInt(f.replace('.txt', '')) || 0)
        .filter(n => n > 0)
        .sort((a, b) => a - b);
    }
  });

  // imports array already contains only scheduled (filtered server-side)
  const scheduledImports = [...imports].sort((a, b) =>
    new Date(a.scheduled_date || a.$createdAt) - new Date(b.scheduled_date || b.$createdAt)
  );

  if (scheduledImports.length > 0) {
    importsTable.style.display = '';
    importsEmpty.style.display = 'none';

    scheduledImports.forEach(imp => {
      const nums  = importLinkedNums[imp.$id] || [];
      const chips = nums.map(n => `<span class="chip-blue">${n}</span>`).join('');
      const scheduled = imp.scheduled_date
        ? new Date(imp.scheduled_date).toLocaleDateString('ja-JP') : '—';

      importsList.insertAdjacentHTML('beforeend', `
        <tr>
          <td style="white-space:nowrap;">${new Date(imp.$createdAt).toLocaleDateString('ja-JP')}</td>
          <td>${imp.quantity}</td>
          <td style="white-space:nowrap;">${scheduled}</td>
          <td>
            <span style="background:#0dcaf0;color:#055160;padding:2px 10px;border-radius:12px;font-size:0.8rem;font-weight:600;">
              入荷予定
            </span>
          </td>
          <td style="line-height:1.8;">${chips || '<em style="color:#aaa;font-size:0.8rem;">—</em>'}</td>
          <td>
            <button class="btn btn-sm btn-outline-primary me-1" onclick="editImport('${imp.$id}')">編集</button>
            <button class="btn btn-sm btn-outline-danger me-1" onclick="deleteImport('${imp.$id}')">削除</button>
            <button class="btn btn-sm btn-success" onclick="confirmArrival('${imp.$id}', ${nums.length || imp.quantity})">
              ✓ 入荷確認
            </button>
          </td>
        </tr>`);
    });
  } else {
    importsTable.style.display = 'none';
    importsEmpty.style.display = '';
  }

  // ─────────────────────────────────────────────────────────────
  // RENDER INVENTORY TAB
  // Groups: finished_inspection → inspection → imported → upcoming_import
  // ─────────────────────────────────────────────────────────────
  const invDiv = document.getElementById('inventoryContent');
  invDiv.innerHTML = '';

  const statusOrder = ['finished_inspection', 'inspection', 'imported', 'upcoming_import'];
  const statusStyles = {
    finished_inspection: {
      bg: '#d1e7dd', chipBg: '#d1e7dd', chipBorder: '#198754',
      borderStyle: 'solid', text: '#0f5132', label: '検査完了 (出荷準備完了)'
    },
    inspection: {
      bg: '#fff9e6', chipBg: '#fff3cd', chipBorder: '#e6a817',
      borderStyle: 'solid', text: '#664d03', label: '検査中'
    },
    imported: {
      bg: '#f0f6ff', chipBg: 'white', chipBorder: '#6ea8fe',
      borderStyle: 'solid', text: '#084298', label: '入荷済 (検査待ち)'
    },
    upcoming_import: {
      bg: '#fafafa', chipBg: 'white', chipBorder: '#adb5bd',
      borderStyle: 'dotted', text: '#495057', label: '入荷予定'
    }
  };

  let hasAny = false;
  statusOrder.forEach(key => {
    const docs = byStatus[key] || [];
    if (docs.length === 0) return;
    hasAny = true;

    const st     = statusStyles[key];
    const groups = groupByLot(docs);

    const lotRows = groups.map(g => {
      const chips = g.nums.map(n =>
        `<span style="display:inline-block;background:${st.chipBg};border:2px ${st.borderStyle} ${st.chipBorder};
         border-radius:4px;padding:2px 9px;font-size:0.82rem;margin:2px;color:${st.text};font-weight:500;">${n}</span>`
      ).join('');
      return `
        <tr style="background:${st.bg}20;">
          <td style="white-space:nowrap;font-weight:600;color:${st.text};font-size:0.88rem;">Lot ${g.lot}</td>
          <td><span style="background:${st.chipBorder};color:white;padding:1px 8px;border-radius:10px;font-size:0.78rem;">${g.nums.length} 個</span></td>
          <td style="line-height:2.0;">${chips}</td>
        </tr>`;
    }).join('');

    invDiv.insertAdjacentHTML('beforeend', `
      <div style="margin-bottom:1.5rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.6rem;">
          <span style="background:${st.bg};border:2px solid ${st.chipBorder};color:${st.text};
            padding:4px 14px;border-radius:20px;font-weight:700;font-size:0.95rem;">${st.label}</span>
          <span style="color:#6c757d;font-size:0.85rem;">${docs.length} 個 / ${groups.length} ロット</span>
        </div>
        <div class="table-responsive">
          <table class="table table-sm" style="margin-bottom:0;">
            <thead style="background:#f8f9fa;">
              <tr>
                <th style="font-size:0.8rem;width:90px;">ロット</th>
                <th style="font-size:0.8rem;width:60px;">数量</th>
                <th style="font-size:0.8rem;">製品番号 (昇順)</th>
              </tr>
            </thead>
            <tbody>${lotRows}</tbody>
          </table>
        </div>
      </div>`);
  });

  if (!hasAny) {
    invDiv.innerHTML = '<p style="color:#6c757d;text-align:center;padding:2rem;">在庫データがありません</p>';
  }
});
</script>
</body>
</html>
