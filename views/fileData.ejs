<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script defer src="/_vercel/insights/script.js"></script>
    <title>測定データ詳細</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
    <style>
      .container { max-width: 1400px; margin-top: 2rem; }
      .file-info { background-color: #f8f9fa; padding: 1.5rem; border-radius: 5px; margin-bottom: 1.5rem; }
      .nav-links { margin-bottom: 2rem; }
      .user-info-banner {
        background: #e3f2fd; padding: 12px 20px; border-radius: 8px; margin-bottom: 20px;
        display: flex; justify-content: space-between; align-items: center; border: 1px solid #90caf9;
      }
      .user-info-left { display: flex; align-items: center; gap: 15px; }
      .auth-badge { padding: 4px 12px; border-radius: 4px; font-size: 13px; font-weight: 500; }
      .badge-edit { background: #d4edda; color: #155724; }
      .badge-readonly { background: #e2e3e5; color: #383d41; }
      .measurements-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-top: 1.5rem;
      }
      .measurement-card {
        background: white;
        border: 2px solid #dee2e6;
        border-radius: 8px;
        padding: 1rem;
        text-align: center;
      }
      .measurement-card.invalid {
        border-color: #dc3545;
        background-color: #fff5f5;
      }
      .measurement-card.valid {
        border-color: #28a745;
        background-color: #f0fff4;
      }
      .measurement-label {
        font-size: 1.2rem;
        font-weight: bold;
        color: #495057;
        margin-bottom: 0.5rem;
      }
      .measurement-value {
        font-size: 1.8rem;
        font-weight: bold;
        color: #212529;
      }
      .measurement-value.invalid {
        color: #dc3545;
      }
      .measurement-value.valid {
        color: #28a745;
      }
      .measurement-status {
        font-size: 0.875rem;
        margin-top: 0.5rem;
        font-weight: 500;
      }
      .inspection-status {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 1rem;
      }
      .inspection-status.pass {
        background: #d4edda;
        color: #155724;
      }
      .inspection-status.fail {
        background: #f8d7da;
        color: #721c24;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1 class="mb-4">ファイルデータ詳細</h1>

      <div class="user-info-banner">
        <div class="user-info-left">
          <div>
            <span style="font-size: 16px;">👤</span>
            <strong><%= displayName %></strong>
          </div>
          
          <% if (canEditWeights) { %>
            <span class="auth-badge badge-edit">✓ 重量編集可</span>
          <% } else { %>
            <span class="auth-badge badge-readonly">📖 閲覧のみ</span>
          <% } %>
        </div>
        
        <a href="/logout" class="btn btn-sm btn-outline-danger">ログアウト</a>
      </div>

      <div class="nav-links">
        <a href="/" class="btn btn-primary">← Home</a>
      </div>

      <% if (typeof file !== 'undefined' && file) { %>
      <div class="file-info">
        <div class="row align-items-center mb-3">
          <div class="col-md-8">
            <h2 style="margin: 0;"><%= file.filename %>.txt</h2>
          </div>
          <div class="col-md-4 text-end">
            <% 
              var status = file.inspectionStatus || 'unknown';
              var statusClass = status === 'pass' ? 'pass' : 'fail';
            %>
            <span class="inspection-status <%= statusClass %>">
              <%= status === 'pass' ? '✓ 合格' : '✗ 不合格' %>
            </span>
          </div>
        </div>

        <div class="row">
          <div class="col-md-4">
            <p><strong>📅 Uploaded:</strong><br><%= new Date(file.uploaded_at).toLocaleString() %></p>
          </div>
          <div class="col-md-4">
            <p>
              <strong>⚖️ Weight:</strong><br>
              <% if (typeof file.weight !== 'undefined' && file.weight !== null) { %>
                <span style="font-size: 1.2rem; font-weight: 600;"><%= Number(file.weight).toFixed(1) %> g</span>
              <% } else { %>
                <span class="text-muted">Not set</span>
              <% } %>
            </p>
          </div>
          <div class="col-md-4">
            <p>
              <strong>📦 生産ロット:</strong><br>
              <% if (file.lot) { %>
                <span style="background: #e3f2fd; padding: 6px 12px; border-radius: 4px; font-weight: 600; font-size: 1.1rem;">
                  <%= file.lot %>
                </span>
              <% } else { %>
                <span class="text-muted">未設定</span>
              <% } %>
            </p>
          </div>
        </div>

        <% if (canEditWeights) { %>
          <hr>
          <form action="/files/<%= file.$id %>/update-weight" method="post" id="weightForm">
            <div class="row align-items-end">
              <div class="col-md-4">
                <label class="form-label"><strong>Update Weight:</strong></label>
                <input type="hidden" name="fileId" value="<%= file.$id %>" />
                <div class="input-group">
                  <input type="text" class="form-control text-end" name="weight"
                    value="<%= file.weight !== null ? Number(file.weight).toFixed(1) : '' %>"
                    placeholder="Enter weight (g)" inputmode="decimal" />
                  <span class="input-group-text">g</span>
                </div>
              </div>
              <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">💾 Save</button>
              </div>
            </div>
          </form>
        <% } else { %>
          <p class="text-muted" style="font-size: 14px; margin-top: 10px; margin-bottom: 0;">
            <em>💡 重量の編集は <strong>naemura</strong> と <strong>iwatsuki</strong> のみ可能です</em>
          </p>
        <% } %>
      </div>
      <% } %> 
      
      <% if (typeof message !== 'undefined' && message) { %>
      <div class="alert alert-info"><%= message %></div>
      <% } %> 
      
      <% if (typeof measurements !== 'undefined' && measurements) { %>
      <h3>測定結果 (Measurements)</h3>
      
      <div class="measurements-grid">
        <% 
          var measurementKeys = ['A', 'B', 'C', 'D', 'E', 'F', 'G1', 'G2', 'G3', 'G4', 'H', 'I', 'J', 'K', 'L'];
          measurementKeys.forEach(function(key) {
            var measurement = measurements[key];
            if (measurement && measurement.value && measurement.value !== '-') {
              var isValid = measurement.isValid !== false;
              var cardClass = isValid ? 'valid' : 'invalid';
              var valueClass = isValid ? 'valid' : 'invalid';
              var statusText = isValid ? '✓ Valid' : '✗ Out of range';
        %>
        <div class="measurement-card <%= cardClass %>">
          <div class="measurement-label"><%= key %></div>
          <div class="measurement-value <%= valueClass %>">
            <%= parseFloat(measurement.value).toFixed(3) %>
          </div>
          <div class="measurement-status <%= valueClass %>">
            <%= statusText %>
          </div>
        </div>
        <% 
            }
          });
        %>
        
        <% if (typeof gValue !== 'undefined' && gValue && gValue !== '-') { %>
        <div class="measurement-card valid" style="grid-column: span 2; background: #e7f3ff;">
          <div class="measurement-label" style="color: #0066cc;">G (Average)</div>
          <div class="measurement-value" style="color: #0066cc; font-size: 2.2rem;">
            <%= parseFloat(gValue).toFixed(3) %>
          </div>
          <div class="measurement-status" style="color: #0066cc;">
            Calculated from G1, G2, G3, G4
          </div>
        </div>
        <% } %>
      </div>
      <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        var weightInput = document.querySelector('input[name="weight"]');
        var weightForm = document.getElementById("weightForm");
        if (weightInput && weightForm) {
          weightInput.addEventListener("keydown", function (event) {
            if (event.key === "Enter") {
              event.preventDefault();
              if (this.value) { weightForm.submit(); }
            }
          });
        }
      });
    </script>
  </body>
</html>
