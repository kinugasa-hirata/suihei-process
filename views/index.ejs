<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>水平ノズル検査</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #f5f5f5; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
    .container { max-width: 1200px; margin: 0 auto; padding: 2rem; }
    .header { background: white; padding: 2rem; border-radius: 8px; margin-bottom: 2rem; box-shadow: 0 2px 8px rgba(0,0,0,0.1); display: flex; justify-content: space-between; align-items: center; }
    .header-left h1 { font-size: 2rem; font-weight: 700; color: #2c3e50; }
    .header-left p { color: #7f8c8d; margin-top: 0.5rem; }
    .header-right { text-align: right; }
    .header-right strong { display: block; color: #2c3e50; }
    .header-right small { display: block; color: #7f8c8d; font-size: 0.9rem; }
    .controls { background: white; padding: 2rem; border-radius: 8px; margin-bottom: 2rem; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    .controls button { padding: 0.75rem 1.5rem; margin: 0.5rem; border: none; border-radius: 4px; background: #0066cc; color: white; cursor: pointer; font-weight: 600; }
    .controls button:hover { background: #0052a3; }
    .file-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1.5rem; }
    .file-card { background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); text-decoration: none; color: inherit; transition: all 0.3s; cursor: pointer; }
    .file-card:hover { transform: translateY(-4px); box-shadow: 0 6px 16px rgba(0,0,0,0.15); }
    .file-number { font-size: 1.8rem; font-weight: 700; color: #0066cc; margin-bottom: 0.5rem; }
    .file-weight { color: #666; font-size: 0.9rem; margin: 0.5rem 0; }
    .status-badge { display: inline-block; padding: 0.4rem 0.8rem; border-radius: 16px; font-size: 0.8rem; font-weight: 600; margin-top: 0.5rem; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="header-left">
        <h1>水平ノズル検査</h1>
        <p>Horizontal Nozzle Inspection System</p>
      </div>
      <div class="header-right">
        <strong><%= displayName %></strong>
        <small>検査管理</small>
        <form action="/logout" method="POST" style="margin-top: 1rem;">
          <button type="submit" class="btn btn-sm btn-outline-secondary">Logout</button>
        </form>
      </div>
    </div>

    <div class="controls">
      <button onclick="selectAll()">Select All</button>
      <button onclick="deselectAll()">Deselect All</button>
      <button onclick="exportToSummary()">Export to Summary</button>
      <button onclick="document.getElementById('importExcel').click()">Import Excel</button>
      <button onclick="exportWeights()">Export Weights</button>
      <input type="file" id="importExcel" style="display: none;" onchange="importExcelWeights()" />
    </div>

    <div class="file-grid">
      <% if (files && files.length > 0) { %>
        <% files.forEach(file => { %>
          <a href="/files/<%= file. %>" class="file-card">
            <input type="checkbox" data-file-id="<%= file. %>" style="margin-right: 0.5rem;" />
            <div class="file-number"><%= file.fileNumber %></div>
            <div class="file-weight">
              <% if (file.weight) { %>
                Weight: <%= file.weight %>g
              <% } else { %>
                <em style="color: #aaa;">未設定</em>
              <% } %>
            </div>
            <div class="status-badge" style="background-color: <%= file.statusColor %>; opacity: <%= file.statusOpacity %>; color: #333;">
              <%= file.statusLabel %>
            </div>
          </a>
        <% }); %>
      <% } else { %>
        <p>No files to display</p>
      <% } %>
    </div>
  </div>

  <script>
    function selectAll() {
      document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = true);
    }
    function deselectAll() {
      document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
    }
    function exportToSummary() {
      const selected = Array.from(document.querySelectorAll('input[type="checkbox"]:checked'))
        .map(cb => cb.getAttribute('data-file-id'))
        .join(',');
      if (selected) window.location.href = '/summary?selectedFiles=' + selected;
    }
    function exportWeights() {
      window.location.href = '/export-weights';
    }
    function importExcelWeights() {
      const file = document.getElementById('importExcel').files[0];
      if (!file) return;
      const formData = new FormData();
      formData.append('file', file);
      fetch('/import-weights', { method: 'POST', body: formData })
        .then(r => r.json())
        .then(data => { alert('Import complete: ' + (data.updated || 0) + ' updated'); location.reload(); })
        .catch(e => alert('Error: ' + e));
    }
  </script>
</body>
</html>
