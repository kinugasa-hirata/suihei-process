<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>水平ノズル検査</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
  <style>
    body { background: #f5f5f5; font-family: sans-serif; }
    .container { max-width: 1200px; margin-top: 2rem; }
    .header { background: white; padding: 2rem; border-radius: 8px; margin-bottom: 2rem; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }

    /* Nav buttons row */
    .nav-bar { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; }

    /* Upload area */
    .upload-zone {
      border: 2px dashed #b0c4de; border-radius: 8px;
      background: white; cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
    }
    .upload-zone:hover, .upload-zone.drag-over { border-color: #0d6efd; background: #f0f6ff; }

    /* File grid */
    .file-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1rem; margin-top: 1rem; }
    .file-card-wrap { position: relative; cursor: pointer; }
    .file-card {
      background: white; padding: 1.2rem; border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      color: inherit; display: block;
      border: 2px solid transparent;
      transition: border-color 0.15s, box-shadow 0.15s;
      user-select: none;
    }
    .file-card:hover { box-shadow: 0 6px 16px rgba(0,0,0,0.15); }
    .file-card-wrap.selected .file-card { border-color: #0d6efd; box-shadow: 0 0 0 3px rgba(13,110,253,0.15); background: #f0f6ff; }
    .file-number { font-size: 1.6rem; font-weight: bold; color: #0066cc; }

    /* Status border styles */
    .file-card.status-upcoming_import { border: 2px dashed #adb5bd; }
    .file-card.status-imported        { border: 2px dashed #6ea8fe; }
    .file-card.status-inspection      { border: 2px dashed #e6a817; background: #fffdf0; }
    .file-card.status-finished_inspection { border: 2px solid #198754; background: #f6fff9; }
    /* Keep selected style dominant */
    .file-card-wrap.selected .file-card { border: 2px solid #0d6efd !important; background: #f0f6ff !important; }

    /* Inline weight input */
    .weight-display { margin: 0.4rem 0; color: #666; font-size: 0.9rem; }
    .weight-edit-row { display: flex; gap: 4px; margin-top: 6px; }
    .weight-edit-row input {
      width: 0; flex: 1; font-size: 0.85rem; padding: 3px 6px;
      border: 1px solid #ced4da; border-radius: 4px; text-align: right;
    }
    .weight-edit-row input:focus { outline: none; border-color: #0d6efd; }
    .weight-save-btn {
      background: #198754; color: white; border: none;
      border-radius: 4px; padding: 3px 8px; font-size: 0.78rem; cursor: pointer; white-space: nowrap;
    }
    .weight-save-btn:hover { background: #157347; }
    .weight-saving { opacity: 0.5; pointer-events: none; }

    /* Status badge */
    .status-badge { display: inline-block; padding: 0.3rem 0.7rem; border-radius: 16px; font-size: 0.78rem; margin-top: 0.4rem; color: #333; }

    /* Result list */
    .result-item { display: flex; align-items: flex-start; gap: 0.5rem; padding: 0.35rem 0; border-bottom: 1px solid #f0f0f0; font-size: 0.88rem; }
    .result-item:last-child { border-bottom: none; }
    .badge-ok   { background: #d1e7dd; color: #0a3622; padding: 2px 7px; border-radius: 4px; white-space: nowrap; font-size: 0.8rem; }
    .badge-upd  { background: #cff4fc; color: #055160; padding: 2px 7px; border-radius: 4px; white-space: nowrap; font-size: 0.8rem; }
    .badge-fail { background: #f8d7da; color: #58151c; padding: 2px 7px; border-radius: 4px; white-space: nowrap; font-size: 0.8rem; }
  </style>
</head>
<body>
<div class="container">

  <!-- ── Header ── -->
  <div class="header">
    <h1>水平ノズル検査</h1>
    <p>Horizontal Nozzle Inspection System</p>
    <div style="margin-top:1rem; display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
      <strong><%= displayName %></strong>
      <% if (canEditWeights) { %>
        <span class="badge bg-success" style="font-size:0.8rem;">✓ 重量編集可</span>
      <% } else { %>
        <span class="badge bg-secondary" style="font-size:0.8rem;">📖 閲覧のみ</span>
      <% } %>
      <form action="/logout" method="POST" style="display:inline; margin-left:auto;">
        <button type="submit" class="btn btn-sm btn-outline-secondary">Logout</button>
      </form>
    </div>
  </div>

  <!-- ── Navigation + Upload combined row ── -->
  <input type="file" id="fileInput" accept=".txt" multiple style="display:none;">
  <% if (canEditWeights) { %>
    <input type="file" id="excelImportInput" accept=".xlsx,.xls" style="display:none;" onchange="doExcelImport(this)">
  <% } %>

  <div class="card mb-3 shadow-sm">
    <div class="card-body py-2" style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
      <!-- Left: nav buttons -->
      <a href="/stock-management" class="btn btn-sm btn-outline-primary">📦 在庫管理</a>
      <a href="/tuika-process" class="btn btn-sm btn-outline-success">➕ 追加工程</a>
      <% if (canEditWeights) { %>
        <a href="/export-weights" class="btn btn-sm btn-outline-secondary">📤 重量エクスポート</a>
        <button class="btn btn-sm btn-outline-success" onclick="document.getElementById('excelImportInput').click()">📥 Excel インポート</button>
      <% } %>

      <!-- Divider -->
      <div style="width:1px; height:24px; background:#dee2e6; margin:0 4px;"></div>

      <!-- Center: upload zone -->
      <div id="dropZone" class="upload-zone" style="flex:1; min-width:200px; padding:0.5rem 1rem; display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap; justify-content:center; min-height:unset; border-radius:6px;">
        <span style="font-size:0.85rem; color:#777;">📄 TXTをドロップ、または</span>
        <button class="btn btn-sm btn-outline-primary" onclick="event.stopPropagation(); document.getElementById('fileInput').click()">📁 選択</button>
        <span id="selectedFilesLabel" class="text-muted" style="font-size:0.82rem;">未選択</span>
        <button class="btn btn-sm btn-success" id="uploadBtn" disabled onclick="event.stopPropagation(); doUpload()">⬆ アップロード</button>
      </div>

      <!-- Divider -->
      <div style="width:1px; height:24px; background:#dee2e6; margin:0 4px;"></div>

      <!-- Right: measurement export -->
      <a href="/export-measurements" class="btn btn-sm btn-outline-secondary" style="opacity:0.55; font-size:0.8rem;">📊 測定値</a>
    </div>
  </div>

  <!-- ── Excel Import Progress ── -->
  <div id="importProgressWrap" class="card mb-3 shadow-sm" style="display:none;">
    <div class="card-body py-2">
      <div class="d-flex align-items-center gap-3">
        <span style="font-size:0.9rem; white-space:nowrap;">Excelインポート中...</span>
        <div class="progress flex-grow-1" style="height:10px;">
          <div id="importProgressBar" class="progress-bar progress-bar-striped progress-bar-animated bg-success" style="width:0%;"></div>
        </div>
        <span id="importProgressText" style="font-size:0.85rem; white-space:nowrap;">0 / 0</span>
      </div>
      <div id="importResult" style="display:none; margin-top:0.5rem; font-size:0.88rem;"></div>
    </div>
  </div>

  <!-- ── Upload results / progress ── -->
  <div class="card mb-4 shadow-sm" id="uploadCard" style="display:none;">
    <div class="card-body py-2">
      <div id="progressWrap" class="mt-3" style="display:none;">
        <div class="progress" style="height:8px;">
          <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" style="width:100%;"></div>
        </div>
        <p class="text-muted mt-1" style="font-size:0.85rem;">アップロード中...</p>
      </div>
      <div id="uploadResults" class="mt-3" style="display:none;">
        <hr class="mt-2 mb-2">
        <h6 id="resultsSummary" class="mb-2"></h6>
        <div id="resultsList"></div>
      </div>
    </div>
  </div>

  <!--
    ════════════════════════════════════════════════════════════
    INDEX.EJS  — Help Panel Snippet
    Paste this block immediately after the upload-results card
    and before the "ファイル一覧" heading section in index.ejs.
    ════════════════════════════════════════════════════════════
  -->

  <!-- ── Help Panel styles (add to <style> in index.ejs) ── -->
  <!--
    Copy the CSS below into the <style> tag of index.ejs.

    .help-panel { ... }   etc.
    (All CSS is inlined on the elements below so you can drop it
    in without touching <style> if preferred.)
  -->

  <!-- ── Help Panel HTML ── -->
  <div id="helpPanel" style="
    background: white;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    margin-bottom: 1.5rem;
    overflow: hidden;
    border: 1px solid #e9ecef;
  ">
    <!-- Collapsible header -->
    <div
      onclick="toggleHelp()"
      style="
        display: flex; justify-content: space-between; align-items: center;
        padding: 0.75rem 1.25rem; cursor: pointer; user-select: none;
        background: #f8f9fa; border-bottom: 1px solid transparent;
        transition: background 0.15s;
      "
      onmouseenter="this.style.background='#eef2f7'"
      onmouseleave="this.style.background='#f8f9fa'"
      id="helpToggleRow"
    >
      <div style="display:flex; align-items:center; gap:0.6rem;">
        <span style="font-size:1rem;">📖</span>
        <span style="font-weight:600; font-size:0.9rem; color:#2c3e50;">
          使い方ガイド — 水平ノズル検査システム
        </span>
        <span style="font-size:0.78rem; color:#6c757d; font-style:italic;">クリックで開閉</span>
      </div>
      <span id="helpChevron" style="font-size:0.85rem; color:#6c757d; transition: transform 0.2s;">▼</span>
    </div>

    <!-- Collapsible body -->
    <div id="helpBody" style="display:none; padding: 1.5rem; border-top: 1px solid #e9ecef;">

      <!-- ── Section 1: What this app does ── -->
      <div style="margin-bottom:1.75rem;">
        <h4 style="font-size:1rem; font-weight:700; color:#2c3e50; margin-bottom:0.75rem; display:flex; align-items:center; gap:0.5rem;">
          🏭 このアプリについて
        </h4>
        <p style="font-size:0.88rem; color:#444; line-height:1.7; margin:0;">
          <strong>水平ノズル検査システム</strong>は、樹脂製水平ノズルの製品検査・在庫・出荷をひとつの画面で管理するためのウェブアプリです。<br>
          3D測定機から出力される <code>.txt</code> ファイルを取り込み、寸法合否判定・重量記録・検査成績書生成・在庫割り当てまでを一貫して行います。
        </p>
      </div>

      <!-- ── Section 2: Status lifecycle ── -->
      <div style="margin-bottom:1.75rem;">
        <h4 style="font-size:1rem; font-weight:700; color:#2c3e50; margin-bottom:0.75rem;">
          🔄 製品ステータスの流れ
        </h4>
        <!-- Flow row -->
        <div style="display:flex; align-items:center; gap:4px; flex-wrap:wrap; margin-bottom:1rem;">

          <div style="text-align:center; padding:0.6rem 0.9rem; background:#fafafa; border:2px dashed #adb5bd; border-radius:8px; font-size:0.78rem; min-width:100px;">
            <div style="font-size:1.1rem;">📦</div>
            <strong>入荷予定</strong>
            <div style="color:#6c757d; font-size:0.72rem; margin-top:3px;">発注後・自動生成</div>
          </div>
          <div style="color:#adb5bd; font-size:1.2rem; padding:0 2px;">→</div>

          <div style="text-align:center; padding:0.6rem 0.9rem; background:#e2f0fb; border:2px solid #6ea8fe; border-radius:8px; font-size:0.78rem; min-width:100px;">
            <div style="font-size:1.1rem;">🚚</div>
            <strong style="color:#084298;">入荷済</strong>
            <div style="color:#6c757d; font-size:0.72rem; margin-top:3px;">入荷確認ボタン</div>
          </div>
          <div style="color:#adb5bd; font-size:1.2rem; padding:0 2px;">→</div>

          <div style="text-align:center; padding:0.6rem 0.9rem; background:#fffdf0; border:2px dashed #e6a817; border-radius:8px; font-size:0.78rem; min-width:100px;">
            <div style="font-size:1.1rem;">🔬</div>
            <strong style="color:#664d03;">検査中</strong>
            <div style="color:#6c757d; font-size:0.72rem; margin-top:3px;">TXTアップロード後</div>
          </div>
          <div style="color:#adb5bd; font-size:1.2rem; padding:0 2px;">→</div>

          <div style="text-align:center; padding:0.6rem 0.9rem; background:#f6fff9; border:2px solid #198754; border-radius:8px; font-size:0.78rem; min-width:100px;">
            <div style="font-size:1.1rem;">✅</div>
            <strong style="color:#0f5132;">検査完了</strong>
            <div style="color:#6c757d; font-size:0.72rem; margin-top:3px;">重量入力・保存後</div>
          </div>
          <div style="color:#adb5bd; font-size:1.2rem; padding:0 2px;">→</div>

          <div style="text-align:center; padding:0.6rem 0.9rem; background:#f0f0f0; border:2px solid #6c757d; border-radius:8px; font-size:0.78rem; min-width:100px;">
            <div style="font-size:1.1rem;">🚢</div>
            <strong style="color:#343a40;">出荷済</strong>
            <div style="color:#6c757d; font-size:0.72rem; margin-top:3px;">在庫管理→出荷後</div>
          </div>

        </div>
        <p style="font-size:0.82rem; color:#6c757d; margin:0;">
          ※ ステータスはすべて<strong>自動で変化</strong>します。Appwriteを直接操作する必要はありません。
        </p>
      </div>

      <!-- ── Section 3: Feature breakdown ── -->
      <div style="margin-bottom:1.75rem;">
        <h4 style="font-size:1rem; font-weight:700; color:#2c3e50; margin-bottom:0.75rem;">
          🛠 主な機能
        </h4>
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:0.75rem;">

          <!-- Card -->
          <div style="border:1px solid #e9ecef; border-radius:8px; padding:1rem; background:#fdfdfd;">
            <div style="font-weight:700; font-size:0.88rem; margin-bottom:0.4rem; color:#0d6efd;">📄 TXTアップロード</div>
            <div style="font-size:0.82rem; color:#555; line-height:1.6;">
              3D測定機出力の <code>.txt</code> を複数同時ドロップ可能。<br>
              寸法 A〜L を自動抽出・合否判定し、既存プレースホルダーを更新します。
            </div>
          </div>

          <div style="border:1px solid #e9ecef; border-radius:8px; padding:1rem; background:#fdfdfd;">
            <div style="font-weight:700; font-size:0.88rem; margin-bottom:0.4rem; color:#198754;">⚖ 重量入力</div>
            <div style="font-size:0.82rem; color:#555; line-height:1.6;">
              各カードから直接入力・保存。保存すると自動的にステータスが<strong>検査完了</strong>に昇格します。<br>
              Excelで一括インポートも可能（naemura / iwatsuki のみ）。
            </div>
          </div>

          <div style="border:1px solid #e9ecef; border-radius:8px; padding:1rem; background:#fdfdfd;">
            <div style="font-weight:700; font-size:0.88rem; margin-bottom:0.4rem; color:#6f42c1;">📋 検査成績書</div>
            <div style="font-size:0.82rem; color:#555; line-height:1.6;">
              カードを複数選択（範囲選択も可）して「検査成績書を表示」。<br>
              寸法・重量・合否を一覧にまとめた印刷用サマリーを生成します。
            </div>
          </div>

          <div style="border:1px solid #e9ecef; border-radius:8px; padding:1rem; background:#fdfdfd;">
            <div style="font-weight:700; font-size:0.88rem; margin-bottom:0.4rem; color:#fd7e14;">➕ 追加工程</div>
            <div style="font-size:0.82rem; color:#555; line-height:1.6;">
              ピンゲージ測定値と検査完了日を記録し、客先提出用 Excel 帳票を生成・クラウド保存します。
            </div>
          </div>

          <div style="border:1px solid #e9ecef; border-radius:8px; padding:1rem; background:#fdfdfd;">
            <div style="font-weight:700; font-size:0.88rem; margin-bottom:0.4rem; color:#20c997;">📦 在庫管理</div>
            <div style="font-size:0.82rem; color:#555; line-height:1.6;">
              発注・入荷・在庫状況・出荷をまとめて管理。<br>
              注文には検査完了品が自動割り当てされ、出荷後は画面から消えます。
            </div>
          </div>

          <div style="border:1px solid #e9ecef; border-radius:8px; padding:1rem; background:#fdfdfd;">
            <div style="font-weight:700; font-size:0.88rem; margin-bottom:0.4rem; color:#dc3545;">🔒 権限管理</div>
            <div style="font-size:0.82rem; color:#555; line-height:1.6;">
              重量の編集・Excel インポートは <strong>naemura</strong> / <strong>iwatsuki</strong> のみ可能。<br>
              他ユーザーは「閲覧のみ」で在庫・成績書の確認ができます。
            </div>
          </div>

        </div>
      </div>

      <!-- ── Section 4: Quick how-to ── -->
      <div>
        <h4 style="font-size:1rem; font-weight:700; color:#2c3e50; margin-bottom:0.75rem;">
          ⚡ よくある操作手順
        </h4>
        <div style="font-size:0.85rem; color:#444; line-height:1.9;">
          <div><span style="display:inline-block;width:20px;text-align:center;">①</span> <strong>新ロット入荷前</strong>：在庫管理 → 入荷管理 → 「新規入荷」でロット数と予定日を登録 → プレースホルダーが自動生成される</div>
          <div><span style="display:inline-block;width:20px;text-align:center;">②</span> <strong>荷物が届いたら</strong>：入荷管理の「入荷確認」を押す → ステータスが「入荷済」に変わる</div>
          <div><span style="display:inline-block;width:20px;text-align:center;">③</span> <strong>3D測定後</strong>：TXTをここにドロップ → 自動抽出・合否判定 → ステータスが「検査中」に変わる</div>
          <div><span style="display:inline-block;width:20px;text-align:center;">④</span> <strong>重量測定後</strong>：各カードの重量欄に入力して「保存」→「検査完了」に昇格</div>
          <div><span style="display:inline-block;width:20px;text-align:center;">⑤</span> <strong>客先への提出書類</strong>：追加工程ページでピンゲージ値を記録 → Excel 帳票をダウンロード</div>
          <div><span style="display:inline-block;width:20px;text-align:center;">⑥</span> <strong>出荷</strong>：在庫管理 → 注文の「出荷」ボタン → 対象製品が画面から消え、出荷済として記録される</div>
        </div>
      </div>

    </div><!-- /helpBody -->
  </div><!-- /helpPanel -->

  <script>
    function toggleHelp() {
      const body    = document.getElementById('helpBody');
      const chevron = document.getElementById('helpChevron');
      const header  = document.getElementById('helpToggleRow');
      const isOpen  = body.style.display !== 'none';
      body.style.display    = isOpen ? 'none' : 'block';
      chevron.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
      header.style.borderBottomColor = isOpen ? 'transparent' : '#e9ecef';
    }
  </script>

  <!-- ── File list heading + toolbar ── -->
  <div class="d-flex align-items-center justify-content-between mb-2 flex-wrap gap-2">
    <h2 class="mb-0">ファイル一覧</h2>
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <span id="selectedCount" class="text-muted" style="font-size:0.9rem;">0 件選択中</span>
      <button class="btn btn-sm btn-outline-secondary" onclick="toggleSelectAll()">全選択 / 解除</button>
      <button class="btn btn-sm btn-primary" id="summaryBtn" disabled onclick="openSummary()">📋 検査成績書を表示</button>
    </div>
  </div>

  <!-- ── Range selector ── -->
  <div class="card mb-3 shadow-sm">
    <div class="card-body py-2">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <span style="font-size:0.9rem; font-weight:600; white-space:nowrap;">範囲選択:</span>
        <label style="font-size:0.85rem; color:#555; white-space:nowrap;">開始番号</label>
        <input type="number" id="rangeStart" class="form-control form-control-sm" style="width:90px;" placeholder="例: 476" min="1">
        <label style="font-size:0.85rem; color:#555; white-space:nowrap;">件数</label>
        <input type="number" id="rangeCount" class="form-control form-control-sm" style="width:70px;" placeholder="例: 3" min="1">
        <button class="btn btn-sm btn-outline-primary" onclick="selectRange()">選択</button>
        <button class="btn btn-sm btn-outline-secondary" onclick="clearSelection()">解除</button>
        <span id="rangeInfo" style="font-size:0.82rem; color:#888;"></span>
      </div>
    </div>
  </div>

  <!-- ── File grid ── -->
  <div class="file-grid">
    <% if (files && files.length > 0) { %>
      <% for (var i = 0; i < files.length; i++) { %>
        <div class="file-card-wrap" id="wrap-<%= files[i].$id %>"
             data-filenumber="<%= files[i].fileNumber %>"
             data-status="<%= files[i].status || 'finished_inspection' %>"
             onclick="toggleCard('<%= files[i].$id %>', event)">
          <input type="checkbox" class="file-checkbox" value="<%= files[i].$id %>"
                 id="cb-<%= files[i].$id %>" style="display:none;" onchange="onCheckChange()">
          <div class="file-card status-<%= files[i].status || 'finished_inspection' %>" id="card-<%= files[i].$id %>">
            <div style="display:flex; justify-content:space-between; align-items:flex-start;">
              <div class="file-number"><%= files[i].fileNumber %></div>
              <span class="select-indicator" id="sel-<%= files[i].$id %>"
                    style="width:20px;height:20px;border-radius:50%;border:2px solid #ccc;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;margin-top:2px;">
              </span>
            </div>
            <div class="weight-display" id="wdisplay-<%= files[i].$id %>">
              <% if (files[i].weight) { %>
                ⚖ <%= files[i].weight %>g
              <% } else if (files[i].status === 'upcoming_import' || files[i].status === 'imported') { %>
                <em style="color:#aaa;">未入荷</em>
              <% } else { %>
                <em style="color:#aaa;">重量未設定</em>
              <% } %>
            </div>
            <% if (canEditWeights && files[i].status !== 'upcoming_import') { %>
              <div class="weight-edit-row" onclick="event.stopPropagation();">
                <input
                  type="text"
                  inputmode="decimal"
                  class="weight-input"
                  id="winput-<%= files[i].$id %>"
                  data-fileid="<%= files[i].$id %>"
                  value="<%= files[i].weight !== null && files[i].weight !== undefined ? files[i].weight : '' %>"
                  placeholder="g"
                  onkeydown="if(event.key==='Enter'){saveWeight('<%= files[i].$id %>')}"
                >
                <button class="weight-save-btn" onclick="event.stopPropagation(); saveWeight('<%= files[i].$id %>')">保存</button>
              </div>
            <% } %>
            <div class="status-badge" data-color="<%= files[i].statusColor || '#e9ecef' %>">
              <%= files[i].statusLabel %>
            </div>
          </div>
        </div>
      <% } %>
    <% } else { %>
      <p class="mt-3">No files to display</p>
    <% } %>
  </div>

</div><!-- /container -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // ── Status badge colors ─────────────────────────────────────────────
  document.querySelectorAll('.status-badge').forEach(el => {
    el.style.backgroundColor = el.dataset.color || '#e9ecef';
  });

  // ── TXT Upload ──────────────────────────────────────────────────────
  const fileInput = document.getElementById('fileInput');
  const dropZone  = document.getElementById('dropZone');
  const uploadBtn = document.getElementById('uploadBtn');
  const label     = document.getElementById('selectedFilesLabel');
  let selectedFiles = null;

  fileInput.addEventListener('change', () => setFiles(fileInput.files));

  function setFiles(files) {
    if (!files || files.length === 0) return;
    const valid = Array.from(files).filter(f => f.name.toLowerCase().endsWith('.txt'));
    if (valid.length === 0) { alert('.txt ファイルのみ対応しています'); return; }
    if (valid.length < files.length) alert(`.txt 以外は除外されました（${files.length - valid.length} 件）`);
    selectedFiles = valid;
    label.textContent = valid.length === 1 ? valid[0].name : `${valid.length} ファイル選択済み`;
    uploadBtn.disabled = false;
    document.getElementById('uploadResults').style.display = 'none';
  }

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', e => { if (!dropZone.contains(e.relatedTarget)) dropZone.classList.remove('drag-over'); });
  dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('drag-over'); setFiles(e.dataTransfer.files); });

  async function doUpload() {
    if (!selectedFiles || selectedFiles.length === 0) return;
    uploadBtn.disabled = true;
    document.getElementById('uploadCard').style.display    = 'block';
    document.getElementById('progressWrap').style.display  = 'block';
    document.getElementById('uploadResults').style.display = 'none';
    const formData = new FormData();
    selectedFiles.forEach(f => formData.append('files', f));
    try {
      const res  = await fetch('/upload', { method: 'POST', body: formData });
      const data = await res.json();
      showUploadResults(data);
    } catch (err) {
      showUploadResults({ success: false, error: err.message });
    } finally {
      document.getElementById('progressWrap').style.display = 'none';
      uploadBtn.disabled = false;
    }
  }

  function showUploadResults(data) {
    const wrap    = document.getElementById('uploadResults');
    const summary = document.getElementById('resultsSummary');
    const list    = document.getElementById('resultsList');
    wrap.style.display = 'block';
    list.innerHTML = '';
    if (!data.success && !data.results) {
      summary.className = 'mb-2 text-danger';
      summary.textContent = '❌ アップロードに失敗しました';
      list.innerHTML = `<p class="text-danger" style="font-size:.9rem;">${data.error || '不明なエラー'}</p>`;
      return;
    }
    const r = data.results || {};
    const ok = r.successful || [], upd = r.updated || [], ng = r.failed || [];
    const total = ok.length + upd.length + ng.length;
    summary.className = 'mb-2 ' + (ng.length === total && total > 0 ? 'text-danger' : 'text-success');
    summary.textContent = `結果: ${ok.length} 件 新規  /  ${upd.length} 件 更新  /  ${ng.length} 件 失敗  — 合計 ${total} 件`;
    ok.forEach(item  => list.insertAdjacentHTML('beforeend', `<div class="result-item"><span class="badge-ok">新規</span><span>${item.filename}</span></div>`));
    upd.forEach(item => list.insertAdjacentHTML('beforeend', `<div class="result-item"><span class="badge-upd">更新</span><span>${item.filename} — プレースホルダーを置換しました</span></div>`));
    ng.forEach(item  => list.insertAdjacentHTML('beforeend', `<div class="result-item"><span class="badge-fail">失敗</span><span>${item.filename} — ${item.error || '不明なエラー'}</span></div>`));
    if (ok.length + upd.length > 0) setTimeout(() => location.reload(), 2000);
  }

  // ── Inline weight save ──────────────────────────────────────────────
  async function saveWeight(fileId) {
    const input = document.getElementById('winput-' + fileId);
    if (!input) return;
    const raw = input.value.trim();
    if (raw === '' ) { alert('重量を入力してください'); return; }
    const val = parseFloat(raw);
    if (isNaN(val) || val < 0) { alert('正しい数値を入力してください'); return; }

    // Visual: dim the row while saving
    input.classList.add('weight-saving');
    const btn = input.nextElementSibling;
    if (btn) btn.classList.add('weight-saving');

    try {
      const res  = await fetch('/update-weight', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ fileId, weight: val })
      });
      const data = await res.json();

      if (data.success) {
        // Update display text without reloading page
        const display = document.getElementById('wdisplay-' + fileId);
        if (display) display.innerHTML = `⚖ ${data.weight}g`;
        input.value = data.weight;
        // Flash the card green briefly
        const card = document.getElementById('card-' + fileId);
        if (card) {
          card.style.transition = 'background 0.3s';
          card.style.background = '#d1e7dd';
          // After weight save, upgrade to finished_inspection style
          setTimeout(() => {
            card.style.background = '';
            card.classList.remove('status-upcoming_import','status-imported','status-inspection');
            card.classList.add('status-finished_inspection');
          }, 800);
        }
      } else {
        alert('保存失敗: ' + (data.error || '不明なエラー'));
      }
    } catch (err) {
      alert('エラー: ' + err.message);
    } finally {
      input.classList.remove('weight-saving');
      if (btn) btn.classList.remove('weight-saving');
    }
  }

  // ── Excel weight import ─────────────────────────────────────────────
  async function doExcelImport(input) {
    if (!input.files || input.files.length === 0) return;
    const file = input.files[0];
    input.value = ''; // reset so same file can be re-selected

    const progressWrap = document.getElementById('importProgressWrap');
    const progressBar  = document.getElementById('importProgressBar');
    const progressText = document.getElementById('importProgressText');
    const resultDiv    = document.getElementById('importResult');

    progressWrap.style.display = 'block';
    resultDiv.style.display    = 'none';
    progressBar.style.width    = '10%';
    progressText.textContent   = '送信中...';

    // Start polling progress
    const pollInterval = setInterval(async () => {
      try {
        const r    = await fetch('/import-progress');
        const prog = await r.json();
        if (prog.total > 0) {
          const pct = Math.round((prog.current / prog.total) * 100);
          progressBar.style.width  = pct + '%';
          progressText.textContent = `${prog.current} / ${prog.total}`;
        }
        if (prog.status === 'complete' || prog.status === 'error') {
          clearInterval(pollInterval);
        }
      } catch(_) {}
    }, 400);

    // Upload the file
    const formData = new FormData();
    formData.append('file', file);

    try {
      const res  = await fetch('/import-weights', { method: 'POST', body: formData });
      const data = await res.json();
      clearInterval(pollInterval);
      progressBar.style.width  = '100%';
      progressText.textContent = '完了';

      resultDiv.style.display = 'block';
      if (data.ok || data.success) {
        resultDiv.innerHTML = `<span class="text-success">✓ ${data.verified || data.updated} 件確認済み・更新完了（未検出: ${data.notFound || 0} 件）</span>`;
        setTimeout(() => location.reload(), 1500);
      } else {
        resultDiv.innerHTML = `<span class="text-danger">❌ インポート失敗: ${data.error || '不明なエラー'}</span>`;
      }
    } catch (err) {
      clearInterval(pollInterval);
      resultDiv.style.display = 'block';
      resultDiv.innerHTML = `<span class="text-danger">❌ エラー: ${err.message}</span>`;
    }
  }

  // ── Card tap toggle ────────────────────────────────────────────────
  function toggleCard(fileId, event) {
    // Don't toggle if clicking on weight input or save button
    if (event.target.tagName === 'INPUT' || event.target.tagName === 'BUTTON') return;
    const wrap = document.getElementById('wrap-' + fileId);
    const status = wrap ? wrap.dataset.status : '';
    // For upcoming/imported placeholders, just toggle selection (no detail page)
    const cb = document.getElementById('cb-' + fileId);
    if (!cb) return;
    cb.checked = !cb.checked;
    onCheckChange();
  }

  // ── Selection UI update ─────────────────────────────────────────────
  function onCheckChange() {
    const checked = document.querySelectorAll('.file-checkbox:checked');
    document.getElementById('selectedCount').textContent = `${checked.length} 件選択中`;
    document.getElementById('summaryBtn').disabled = checked.length === 0;
    document.querySelectorAll('.file-card-wrap').forEach(wrap => {
      const cb = wrap.querySelector('.file-checkbox');
      const isChecked = cb && cb.checked;
      wrap.classList.toggle('selected', isChecked);
      // Update circle indicator
      const sel = document.getElementById('sel-' + (cb ? cb.value : ''));
      if (sel) {
        if (isChecked) {
          sel.style.background = '#0d6efd';
          sel.style.border = '2px solid #0d6efd';
          sel.style.color = 'white';
          sel.textContent = '✓';
        } else {
          sel.style.background = 'transparent';
          sel.style.border = '2px solid #ccc';
          sel.style.color = '';
          sel.textContent = '';
        }
      }
    });
  }

  function toggleSelectAll() {
    const all     = document.querySelectorAll('.file-checkbox');
    const checked = document.querySelectorAll('.file-checkbox:checked');
    const doCheck = checked.length < all.length;
    all.forEach(cb => { cb.checked = doCheck; });
    onCheckChange();
  }

  function clearSelection() {
    document.querySelectorAll('.file-checkbox').forEach(cb => { cb.checked = false; });
    onCheckChange();
    document.getElementById('rangeInfo').textContent = '';
  }

  // ── Range selection ─────────────────────────────────────────────────
  function selectRange() {
    const start = parseInt(document.getElementById('rangeStart').value);
    const count = parseInt(document.getElementById('rangeCount').value);
    const info  = document.getElementById('rangeInfo');

    if (isNaN(start) || isNaN(count) || count < 1) {
      info.textContent = '開始番号と件数を入力してください';
      info.style.color = '#dc3545';
      return;
    }

    const end = start + count - 1;

    // First clear all
    document.querySelectorAll('.file-checkbox').forEach(cb => { cb.checked = false; });

    // Select cards whose file number falls in [start, end]
    let found = 0;
    document.querySelectorAll('.file-card-wrap').forEach(wrap => {
      const num = parseInt(wrap.dataset.filenumber);
      if (num >= start && num <= end) {
        const cb = wrap.querySelector('.file-checkbox');
        if (cb) { cb.checked = true; found++; }
      }
    });

    onCheckChange();

    if (found === 0) {
      info.textContent = `${start}〜${end} は見つかりませんでした`;
      info.style.color = '#dc3545';
    } else {
      info.textContent = `${start}〜${end}（${found} 件選択）`;
      info.style.color = '#198754';
    }
  }

  // Allow pressing Enter in range inputs
  document.getElementById('rangeStart').addEventListener('keydown', e => { if (e.key === 'Enter') selectRange(); });
  document.getElementById('rangeCount').addEventListener('keydown', e => { if (e.key === 'Enter') selectRange(); });

  function openSummary() {
    const ids = Array.from(document.querySelectorAll('.file-checkbox:checked'))
                     .map(cb => cb.value).join(',');
    if (!ids) return;
    window.open(`/summary?selectedFiles=${ids}`, '_blank');
  }
</script>
</body>
</html>
